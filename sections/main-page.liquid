<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

{%- if page.handle == 'vetements' -%}
  <div class="f2d2-clothing-fallback section--padding">
    <div class="page-width">
      <div class="f2d2-clothing-fallback__header">
        <p>Vêtements</p>
        <h1>Magasinez par collection</h1>
        <div class="rte">
          <p>Retrouvez nos collections de vêtements pour hommes, femmes et toute la famille.</p>
        </div>
      </div>

      <div class="f2d2-clothing-fallback__filter">
        <span class="f2d2-clothing-fallback__filter-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M4 5h16l-6 7v5l-4 2v-7L4 5Z"/></svg>
        </span>
        <label for="F2D2ClothingFilter-{{ section.id }}">Filtrer les collections</label>
        <div class="f2d2-clothing-fallback__select-wrap">
          <span class="f2d2-clothing-fallback__select-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M4 4h6v6H4V4Z"/><path d="M14 4h6v6h-6V4Z"/><path d="M4 14h6v6H4v-6Z"/><path d="M14 14h6v6h-6v-6Z"/></svg>
          </span>
          <select id="F2D2ClothingFilter-{{ section.id }}" data-f2d2-clothing-filter hidden>
            <option value="all">Toutes les collections</option>
            {%- for collection in collections -%}
              {%- liquid
                assign collection_handle = collection.handle
                assign collection_search = collection.title | append: ' ' | append: collection.handle | handle
                assign is_clothing_collection = false

                if collection_search contains 'vetement' or collection_search contains 't-shirt' or collection_search contains 't-shirts' or collection_search contains 'chandail' or collection_search contains 'hoodie' or collection_search contains 'homme' or collection_search contains 'femme' or collection_search contains 'enfant'
                  assign is_clothing_collection = true
                endif

                if collection_handle == 'vetements' or collection_handle == 'tous-nos-vetements' or collection_handle == 'tous-les-vetements'
                  assign is_clothing_collection = false
                endif

                unless is_clothing_collection
                  continue
                endunless
              -%}
              <option value="{{ collection.handle | escape }}">{{ collection.title | escape }}</option>
            {%- endfor -%}
          </select>
          <button
            class="f2d2-clothing-fallback__select-button"
            type="button"
            aria-haspopup="listbox"
            aria-expanded="false"
            aria-controls="F2D2ClothingMenu-{{ section.id }}"
            data-f2d2-clothing-filter-button
          >
            <span data-f2d2-clothing-filter-label>Toutes les collections</span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <ul
            class="f2d2-clothing-fallback__select-menu"
            id="F2D2ClothingMenu-{{ section.id }}"
            role="listbox"
            tabindex="-1"
            data-f2d2-clothing-filter-menu
            hidden
          ></ul>
        </div>
      </div>

      <div class="f2d2-clothing-fallback__grid">
        {%- assign shown_clothing_collections = 0 -%}
        {%- for collection in collections -%}
          {%- liquid
            assign collection_handle = collection.handle
            assign collection_search = collection.title | append: ' ' | append: collection.handle | handle
            assign is_clothing_collection = false

            if collection_search contains 'vetement' or collection_search contains 't-shirt' or collection_search contains 't-shirts' or collection_search contains 'chandail' or collection_search contains 'hoodie' or collection_search contains 'homme' or collection_search contains 'femme' or collection_search contains 'enfant'
              assign is_clothing_collection = true
            endif

            if collection_handle == 'vetements' or collection_handle == 'tous-nos-vetements' or collection_handle == 'tous-les-vetements'
              assign is_clothing_collection = false
            endif

            unless is_clothing_collection
              continue
            endunless

            assign shown_clothing_collections = shown_clothing_collections | plus: 1
            assign title = collection.title
            assign description = collection.description | strip_html | strip
            if description == blank
              assign description = 'Découvrez cette collection de vêtements.'
            endif
            assign first_product = collection.products.first
            assign image = first_product.featured_media.preview_image
            if image == blank
              assign image = first_product.featured_image
            endif
            if image == blank
              assign image = first_product.images.first
            endif
            if image == blank
              assign image = collection.image
            endif
          -%}
          <article class="f2d2-clothing-fallback-card" data-f2d2-clothing-card data-collection-handle="{{ collection.handle | escape }}">
            <a href="{{ collection.url | default: routes.collections_url }}" class="f2d2-clothing-fallback-card__link">
              <div class="f2d2-clothing-fallback-card__media">
                {%- if image != blank -%}
                  {{
                    image
                    | image_url: width: 900
                    | image_tag:
                      loading: 'lazy',
                      widths: '320, 520, 720, 900',
                      sizes: '(max-width: 749px) 90vw, (max-width: 1199px) 45vw, 31vw',
                      class: 'f2d2-clothing-fallback-card__image'
                  }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'f2d2-clothing-fallback-card__placeholder' }}
                {%- endif -%}
              </div>
              <div class="f2d2-clothing-fallback-card__content">
                <h2>{{ title | escape }}</h2>
                <p>{{ description | escape }}</p>
                <span class="f2d2-clothing-fallback-card__button">
                  Voir la collection
                  <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h11"/><path d="m11 6 4 4-4 4"/></svg>
                </span>
              </div>
            </a>
          </article>
        {%- endfor -%}
        {%- if shown_clothing_collections == 0 -%}
          <p class="f2d2-clothing-fallback__empty">
            Aucune collection de vêtements n'est disponible pour le moment.
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>
  <script>
    (() => {
      const section = document.getElementById('shopify-section-{{ section.id }}');
      if (!section) return;

      const filter = section.querySelector('[data-f2d2-clothing-filter]');
      const button = section.querySelector('[data-f2d2-clothing-filter-button]');
      const buttonLabel = section.querySelector('[data-f2d2-clothing-filter-label]');
      const menu = section.querySelector('[data-f2d2-clothing-filter-menu]');
      const cards = section.querySelectorAll('[data-f2d2-clothing-card]');
      if (!filter || !button || !buttonLabel || !menu || !cards.length) return;

      const closeMenu = () => {
        menu.hidden = true;
        button.setAttribute('aria-expanded', 'false');
      };

      const openMenu = () => {
        menu.hidden = false;
        button.setAttribute('aria-expanded', 'true');
      };

      const applyFilter = (value) => {
        filter.value = value;
        const selectedOption = filter.options[filter.selectedIndex];
        buttonLabel.textContent = selectedOption ? selectedOption.textContent : 'Toutes les collections';
        cards.forEach((card) => {
          card.hidden = value !== 'all' && card.dataset.collectionHandle !== value;
        });
        menu.querySelectorAll('[role="option"]').forEach((option) => {
          option.setAttribute('aria-selected', String(option.dataset.value === value));
        });
      };

      Array.from(filter.options).forEach((option) => {
        const item = document.createElement('li');
        item.className = 'f2d2-clothing-fallback__select-option';
        item.setAttribute('role', 'option');
        item.setAttribute('aria-selected', String(option.value === filter.value));
        item.dataset.value = option.value;
        item.textContent = option.textContent;
        menu.appendChild(item);
      });

      button.addEventListener('click', () => {
        menu.hidden ? openMenu() : closeMenu();
      });

      menu.addEventListener('click', (event) => {
        const option = event.target.closest('[role="option"]');
        if (!option) return;
        applyFilter(option.dataset.value);
        closeMenu();
      });

      document.addEventListener('click', (event) => {
        if (section.contains(event.target) && event.target.closest('.f2d2-clothing-fallback__select-wrap')) return;
        closeMenu();
      });

      section.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeMenu();
          button.focus();
        }
      });
    })();
  </script>
{%- else -%}
  <div class="page-width page-width--narrow section--padding">
    <h1 class="main-page-title page-title h1 text-center">
      <motion-element class="inline-flex" data-motion="fade-up">
        {{ page.title | escape }}
      </motion-element>
    </h1>
    <div class="page__content rte">
      {{ page.content }}
    </div>
  </div>
{%- endif -%}

{% style %}
{%- if page.handle == 'vetements' -%}

/* =========================================================
   F2D2 COLLECTION PAGE
========================================================= */

#shopify-section-{{ section.id }} {
  background:
    radial-gradient(circle at top, rgba(0, 92, 214, 0.25), transparent 35rem),
    linear-gradient(135deg, #04090d 0%, #071018 50%, #020507 100%);
}

/* =========================================================
   MAIN CONTAINER
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback {
  color: #ffffff;
}

/* =========================================================
   HEADER
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__header {
  max-width: 76rem;
  margin: 0 auto 3.5rem;
  text-align: center;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__header > p {
  margin: 0 0 1rem;

  color: #28a5ff;

  font-size: 1.3rem;
  font-weight: 800;

  letter-spacing: 0.12em;
  text-transform: uppercase;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback h1 {
  margin: 0;

  color: #ffffff;

  font-size: clamp(3.2rem, 5vw, 5.6rem);
  line-height: 1.05;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__header .rte {
  max-width: 58rem;

  margin: 1.6rem auto 0;

  color: rgba(255,255,255,0.72);

  font-size: 1.7rem;
  line-height: 1.6;
}

/* =========================================================
   FILTER
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__filter {
  position: relative;
  z-index: 1000;

  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.6rem;

  max-width: 82rem;

  margin: 0 auto 4rem;

  padding: 1.4rem 2rem;

  border: 1px solid rgba(61, 140, 255, 0.45);
  border-radius: 999px;

  background:
    radial-gradient(circle at top, rgba(0, 119, 255, 0.14), transparent 55%),
    rgba(5, 12, 22, 0.82);

  box-shadow:
    inset 0 0 0 1px rgba(255,255,255,0.03),
    0 0 2.6rem rgba(0, 102, 255, 0.12);

  -webkit-backdrop-filter: blur(14px);
  backdrop-filter: blur(14px);
}

/* =========================================================
   FILTER LABEL
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__filter-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  width: 2.8rem;
  height: 2.8rem;

  color: #ffffff;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__filter-icon svg {
  width: 2rem;
  height: 2rem;

  fill: none;
  stroke: currentColor;
  stroke-width: 1.8;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__filter label {
  color: rgba(255,255,255,0.72);

  font-size: 1.7rem;
  font-weight: 600;

  white-space: nowrap;
}

/* =========================================================
   SELECT
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-wrap {
  position: relative;
  z-index: 1001;

  display: flex;
  align-items: center;

  flex: 1 1 34rem;
  min-width: 24rem;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-icon {
  position: absolute;
  left: 1.2rem;

  z-index: 2;

  display: inline-flex;
  align-items: center;
  justify-content: center;

  width: 3.6rem;
  height: 3.6rem;

  border-radius: 50%;

  color: #ffffff;

  background:
    linear-gradient(145deg, #1684ff, #0048bb);

  box-shadow:
    0 0 1.8rem rgba(0, 102, 255, 0.32);

  pointer-events: none;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-icon svg {
  width: 1.8rem;
  height: 1.8rem;

  fill: currentColor;
}

/* =========================================================
   SELECT BUTTON
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.4rem;

  width: 100%;
  min-height: 5.6rem;

  padding: 0 2rem 0 6rem;

  border: 1px solid rgba(91, 177, 255, 0.35);
  border-radius: 999px;

  color: #ffffff;

  background:
    linear-gradient(
      180deg,
      rgba(10, 18, 32, 0.92),
      rgba(3, 8, 15, 0.96)
    );

  box-shadow:
    inset 0 0 0 1px rgba(255,255,255,0.03),
    0 0 1.8rem rgba(0, 102, 255, 0.08);

  font-size: 1.7rem;
  font-weight: 700;

  cursor: pointer;

  transition:
    border-color 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-button:hover,
#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-button:focus {
  outline: none;

  border-color: rgba(91,177,255,0.75);

  box-shadow:
    0 0 2.4rem rgba(0, 102, 255, 0.18);
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-button > span {
  min-width: 0;

  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-button > svg {
  width: 1.8rem;
  height: 1.8rem;

  flex: 0 0 auto;

  fill: none;
  stroke: currentColor;
  stroke-width: 2;
}

/* =========================================================
   DROPDOWN MENU
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-menu {
  position: absolute;

  top: calc(100% + 1rem);
  left: 0;

  z-index: 1040;

  width: 100%;
  max-height: 30rem;

  margin: 0;
  padding: 0.8rem;

  overflow-y: auto;

  list-style: none;

  border: 1px solid rgba(91,177,255,0.38);
  border-radius: 2rem;

  background:
    linear-gradient(
      180deg,
      rgba(9,18,32,0.98),
      rgba(3,8,16,0.98)
    );

  box-shadow:
    0 2rem 4rem rgba(0,0,0,0.45),
    0 0 2rem rgba(0,102,255,0.12);
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-menu[hidden] {
  display: none;
}

/* =========================================================
   SCROLLBAR
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-menu::-webkit-scrollbar {
  width: 8px;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-menu::-webkit-scrollbar-track {
  background: rgba(5,12,22,0.9);
  border-radius: 999px;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-menu::-webkit-scrollbar-thumb {
  background:
    linear-gradient(
      180deg,
      #1f8fff,
      #005eff
    );

  border-radius: 999px;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-menu {
  scrollbar-width: thin;
  scrollbar-color: #0b6cff rgba(5,12,22,0.9);
}

/* =========================================================
   OPTIONS
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-option {
  padding: 1.3rem 1.8rem;

  border-radius: 1.4rem;

  color: rgba(255,255,255,0.82);

  font-size: 1.6rem;
  font-weight: 700;

  cursor: pointer;

  transition:
    background 180ms ease,
    color 180ms ease;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-option:hover,
#shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-option[aria-selected="true"] {
  color: #ffffff;

  background:
    linear-gradient(
      135deg,
      rgba(22,128,255,0.85),
      rgba(0,75,189,0.8)
    );
}

/* =========================================================
   GRID
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback__grid {
  display: grid;

  grid-template-columns: repeat(3, minmax(0, 1fr));

  gap: 2.4rem;

  align-items: stretch;
}

/* =========================================================
   CARDS
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback-card {
  position: relative;

  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 1rem;

  background:
    linear-gradient(
      180deg,
      rgba(255,255,255,0.06),
      rgba(255,255,255,0.02)
    ),
    rgba(5,10,14,0.82);

  overflow: hidden;

  transition:
    transform 180ms ease,
    border-color 180ms ease,
    box-shadow 180ms ease;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback-card:hover {
  transform: translateY(-4px);

  border-color: rgba(69,158,255,0.55);

  box-shadow:
    0 1.6rem 4rem rgba(0,91,255,0.12);
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback-card__link {
  display: grid;
  grid-template-rows: minmax(24rem, 1fr) auto;

  min-height: 42rem;

  color: inherit;
  text-decoration: none;
}

/* =========================================================
   CARD IMAGE
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback-card__media {
  display: flex;
  align-items: center;
  justify-content: center;

  min-height: 24rem;

  padding: 2rem;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback-card__image,
#shopify-section-{{ section.id }} .f2d2-clothing-fallback-card__placeholder {
  width: 100%;
  height: 100%;

  max-height: 24rem;

  object-fit: contain;

  filter:
    drop-shadow(0 2rem 2.4rem rgba(0,0,0,0.5));
}

/* =========================================================
   CARD CONTENT
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback-card__content {
  display: flex;
  flex-direction: column;
  align-items: center;

  padding: 0 2rem 2rem;

  text-align: center;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback-card__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  width: 4.8rem;
  height: 4.8rem;

  margin: -1rem 0 1rem;

  border-radius: 50%;

  color: #ffffff;

  background:
    linear-gradient(145deg, #0f7cff, #0047b7);

  box-shadow:
    0 1rem 3rem rgba(0,91,255,0.3);
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback-card h2 {
  margin: 0 auto;

  max-width: 24rem;

  color: #ffffff;

  font-size: 1.8rem;
  line-height: 1.2;

  text-transform: uppercase;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback-card p {
  margin: 1rem 0 2rem;

  color: rgba(255,255,255,0.66);

  font-size: 1.45rem;
}

/* =========================================================
   BUTTON
========================================================= */

#shopify-section-{{ section.id }} .f2d2-clothing-fallback-card__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.8rem;
  white-space: nowrap;

  min-height: 4.2rem;

  margin-top: auto;

  padding: 0.85rem 1.6rem;

  border: 1px solid rgba(255,255,255,0.16);
  border-radius: 999px;

  color: #ffffff;

  background: rgba(255,255,255,0.03);

  font-size: 1.35rem;
  font-weight: 700;

  transition:
    border-color 180ms ease,
    background 180ms ease,
    transform 180ms ease;
}

#shopify-section-{{ section.id }} .f2d2-clothing-fallback-card:hover .f2d2-clothing-fallback-card__button {
  border-color: rgba(91,177,255,0.65);

  background:
    rgba(15,124,255,0.14);
}

/* =========================================================
   MOBILE
========================================================= */

@media (max-width: 989px) {

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback__header {
    margin-bottom: 2.2rem;
  }

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback h1 {
    font-size: 3.6rem;
  }

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback__header .rte {
    font-size: 1.45rem;
    line-height: 1.5;

    margin-top: 1.2rem;
  }

  /* FILTER */

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback__filter {
    flex-direction: row;

    gap: 1rem;

    max-width: 100%;

    margin-bottom: 2.6rem;

    padding: 1rem 1.2rem;

    border-radius: 2rem;
  }

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback__filter-icon,
  #shopify-section-{{ section.id }} .f2d2-clothing-fallback__filter label {
    display: none;
  }

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-wrap {
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-icon {
    width: 3.2rem;
    height: 3.2rem;

    left: 1rem;
  }

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-button {
    min-height: 5rem;

    padding-left: 5.2rem;

    font-size: 1.5rem;
  }

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback__select-option {
    font-size: 1.45rem;
  }

  /* GRID */

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback__grid {
    grid-template-columns: 1fr;

    gap: 1.8rem;
  }

  /* CARD */

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback-card__link {
    min-height: 40rem;
  }

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback-card__media {
    min-height: 20rem;
    padding: 1.8rem;
  }

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback-card h2 {
    font-size: 1.8rem;
  }

  #shopify-section-{{ section.id }} .f2d2-clothing-fallback-card p {
    font-size: 1.35rem;
  }
}

{%- endif -%}
{% endstyle %}

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",

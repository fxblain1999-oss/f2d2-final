{{ 'f2d2-web-hero-crop.png' | asset_url | preload_tag: as: 'image' }}

<style>
  body:has(.f2d2-web-page) .main-page-title {
    display: none;
  }

  body:has(.f2d2-web-page) .page__content:empty {
    display: none;
  }

  body:has(.f2d2-web-page) .section--padding {
    padding-top: 0;
    padding-bottom: 0;
  }

  body:has(.f2d2-web-page) .announcement-bar-section {
    display: none;
  }

  .f2d2-web-page {
    --web-blue: #0084ff;
    --web-blue-strong: #0068d8;
    --web-line: rgba(255, 255, 255, 0.14);
    --web-muted: rgba(255, 255, 255, 0.72);
    background: #020406;
    color: #fff;
    overflow: hidden;
  }

  .f2d2-web-page * {
    box-sizing: border-box;
  }

  .f2d2-web-page__inner {
    width: min(1440px, calc(100% - 48px));
    margin: 0 auto;
  }

  .f2d2-web-hero {
    position: relative;
    width: 100%;
    min-height: 760px;
    display: flex;
    align-items: center;
    padding: 116px 0 54px;
    background:
      linear-gradient(90deg, #020406 0%, rgba(2, 4, 6, 0.94) 26%, rgba(2, 4, 6, 0.42) 56%, rgba(2, 4, 6, 0.08) 100%),
      linear-gradient(180deg, rgba(2, 4, 6, 0) 70%, #020406 100%),
      url({{ 'f2d2-web-hero-crop.png' | asset_url }}) center top / 100% auto no-repeat;
  }

  .f2d2-web-hero__content {
    max-width: 600px;
  }

  .f2d2-web-eyebrow {
    color: var(--web-blue);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
    margin: 0 0 18px;
  }

  .f2d2-web-hero h2 {
    margin: 0;
    color: #fff;
    font-size: clamp(56px, 6.5vw, 94px);
    line-height: 0.95;
    font-weight: 900;
    letter-spacing: 0;
  }

  .f2d2-web-hero__lead {
    margin: 24px 0 0;
    max-width: 430px;
    color: rgba(255, 255, 255, 0.84);
    font-size: 25px;
    line-height: 1.22;
  }

  .f2d2-web-hero__copy {
    margin: 20px 0 0;
    max-width: 420px;
    color: var(--web-muted);
    font-size: 16px;
    line-height: 1.55;
  }

  .f2d2-web-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 34px;
  }

  .f2d2-web-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 28px;
    border: 1px solid var(--web-line);
    border-radius: 4px;
    color: #fff;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .f2d2-web-btn:hover {
    transform: translateY(-2px);
    border-color: var(--web-blue);
  }

  .f2d2-web-btn--primary {
    border-color: var(--web-blue);
    background: linear-gradient(135deg, var(--web-blue-strong), var(--web-blue));
  }

  .f2d2-web-feature-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-top: 0;
    margin-bottom: 58px;
    border: 1px solid var(--web-line);
    border-radius: 6px;
    background: rgba(8, 13, 20, 0.82);
    backdrop-filter: blur(16px);
  }

  .f2d2-web-feature {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 16px;
    align-items: center;
    min-height: 96px;
    padding: 24px 32px;
    border-right: 1px solid var(--web-line);
  }

  .f2d2-web-feature:last-child {
    border-right: 0;
  }

  .f2d2-web-icon {
    width: 42px;
    height: 42px;
    color: var(--web-blue);
  }

  .f2d2-web-feature strong,
  .f2d2-web-card h3,
  .f2d2-web-plan h3,
  .f2d2-web-proof strong {
    display: block;
    color: #fff;
    font-weight: 800;
  }

  .f2d2-web-feature p,
  .f2d2-web-card p,
  .f2d2-web-plan p,
  .f2d2-web-proof span,
  .f2d2-web-cta p,
  .f2d2-web-section-head p {
    margin: 0;
    color: var(--web-muted);
    line-height: 1.45;
  }

  .f2d2-web-feature p {
    font-size: 13px;
  }

  .f2d2-web-block {
    padding: 20px 0 68px;
  }

  .f2d2-web-section-head {
    text-align: center;
    margin-bottom: 42px;
  }

  .f2d2-web-section-head h2,
  .f2d2-web-hosting h2,
  .f2d2-web-cta h2 {
    margin: 0;
    color: #fff;
    font-size: clamp(30px, 4vw, 42px);
    line-height: 1.1;
    font-weight: 900;
    letter-spacing: 0;
  }

  .f2d2-web-section-head h2::after {
    content: "";
    display: block;
    width: 40px;
    height: 2px;
    margin: 18px auto 0;
    background: var(--web-blue);
  }

  .f2d2-web-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .f2d2-web-card,
  .f2d2-web-plan,
  .f2d2-web-proof,
  .f2d2-web-cta {
    border: 1px solid var(--web-line);
    border-radius: 6px;
    background: linear-gradient(145deg, rgba(17, 24, 34, 0.92), rgba(5, 8, 13, 0.96));
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.32);
  }

  .f2d2-web-card {
    padding: 34px 28px 26px;
  }

  .f2d2-web-card h3 {
    margin: 20px 0 10px;
    font-size: 21px;
  }

  .f2d2-web-card p {
    min-height: 72px;
    font-size: 14px;
  }

  .f2d2-web-list {
    display: grid;
    gap: 10px;
    margin: 20px 0 24px;
    padding: 0;
    list-style: none;
  }

  .f2d2-web-list li {
    position: relative;
    padding-left: 22px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 13px;
    line-height: 1.35;
  }

  .f2d2-web-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--web-blue);
    font-weight: 900;
  }

  .f2d2-web-card__link {
    width: 100%;
    min-height: 44px;
    padding: 0 16px;
    color: var(--web-blue);
    border-color: var(--web-blue);
  }

  .f2d2-web-hosting {
    padding: 14px 0 64px;
  }

  .f2d2-web-hosting h2 span {
    color: var(--web-blue);
  }

  .f2d2-web-hosting > p {
    margin: 8px 0 20px;
    color: var(--web-muted);
    font-size: 16px;
  }

  .f2d2-web-pricing {
    display: grid;
    grid-template-columns: repeat(3, 1fr) 1.1fr;
    gap: 24px;
    align-items: stretch;
  }

  .f2d2-web-plan {
    position: relative;
    padding: 34px 28px 26px;
    text-align: center;
  }

  .f2d2-web-plan--featured {
    border-color: rgba(0, 132, 255, 0.72);
    background: linear-gradient(160deg, rgba(12, 72, 126, 0.82), rgba(5, 8, 13, 0.96) 48%);
  }

  .f2d2-web-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 5px 18px;
    border-radius: 4px;
    background: var(--web-blue);
    color: #fff;
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .f2d2-web-plan h3 {
    margin: 0 0 5px;
    font-size: 20px;
  }

  .f2d2-web-plan p {
    font-size: 13px;
  }

  .f2d2-web-price {
    margin: 22px 0 6px;
    color: var(--web-blue);
    font-size: 37px;
    font-weight: 900;
    line-height: 1;
  }

  .f2d2-web-price small {
    font-size: 16px;
    font-weight: 800;
  }

  .f2d2-web-proof {
    display: grid;
    gap: 21px;
    padding: 32px 28px;
  }

  .f2d2-web-proof__item {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 14px;
    align-items: center;
  }

  .f2d2-web-proof .f2d2-web-icon {
    width: 36px;
    height: 36px;
    padding: 8px;
    border-radius: 999px;
    background: rgba(0, 132, 255, 0.15);
  }

  .f2d2-web-proof span {
    display: block;
    font-size: 12px;
  }

  .f2d2-web-cta {
    display: grid;
    grid-template-columns: 92px 1fr auto;
    gap: 34px;
    align-items: center;
    padding: 30px 38px;
    margin-bottom: 70px;
  }

  .f2d2-web-code {
    display: grid;
    place-items: center;
    width: 82px;
    height: 82px;
    border: 2px solid var(--web-blue);
    border-radius: 10px;
    color: var(--web-blue);
    font-size: 38px;
    font-weight: 900;
  }

  .f2d2-web-cta h2 {
    font-size: clamp(26px, 3vw, 34px);
  }

  @media (max-width: 990px) {
    .f2d2-web-hero {
      min-height: auto;
      align-items: center;
      padding: 28px 0 34px;
      background:
        linear-gradient(180deg, rgba(2, 4, 6, 0.12), rgba(2, 4, 6, 0.9) 58%, #020406 100%),
        url({{ 'f2d2-web-hero-crop.png' | asset_url }}) center top / auto 94% no-repeat;
    }

    .f2d2-web-hero__content {
      max-width: 620px;
      margin: 0 auto;
      padding-top: clamp(60px, 12svh, 100px);
      text-align: center;
    }

    .f2d2-web-hero__lead,
    .f2d2-web-hero__copy {
      margin-left: auto;
      margin-right: auto;
    }

    .f2d2-web-actions {
      justify-content: center;
      margin-top: 28px;
    }

    .f2d2-web-feature-strip {
      margin-top: 120px;
    }

    .f2d2-web-feature-strip,
    .f2d2-web-grid,
    .f2d2-web-pricing,
    .f2d2-web-cta {
      grid-template-columns: 1fr;
    }

    .f2d2-web-feature {
      border-right: 0;
      border-bottom: 1px solid var(--web-line);
    }

    .f2d2-web-feature:last-child {
      border-bottom: 0;
    }

    .f2d2-web-card p {
      min-height: 0;
    }

    .f2d2-web-cta {
      text-align: center;
      justify-items: center;
    }
  }

  @media (max-width: 640px) {
    .f2d2-web-page__inner {
      width: min(100% - 24px, 1120px);
    }

    .f2d2-web-hero h2 {
      font-size: 46px;
    }

    .f2d2-web-hero__lead {
      font-size: 21px;
    }

    .f2d2-web-actions {
      display: grid;
    }

    .f2d2-web-btn {
      width: 100%;
    }
  }
</style>


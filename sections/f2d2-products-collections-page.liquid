{%- liquid
  assign category_blocks = section.blocks | where: 'type', 'category'
-%}

<section class="f2d2-products-page section-{{ section.id }}">
  <div class="f2d2-products-page__glow" aria-hidden="true"></div>

  <div class="f2d2-products-page__inner page-width">

    <div class="f2d2-products-page__hero">
      {%- if section.settings.eyebrow != blank -%}
        <p class="f2d2-products-page__eyebrow">
          {{ section.settings.eyebrow | escape }}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1>{{ section.settings.heading | escape }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="f2d2-products-page__intro rte">
          {{ section.settings.text }}
        </div>
      {%- endif -%}

      <a
        href="{{ routes.all_products_collection_url }}"
        class="f2d2-products-page__all-button"
      >
        Tous nos produits

        <svg viewBox="0 0 20 20" aria-hidden="true">
          <path d="M4 10h11"/>
          <path d="m11 6 4 4-4 4"/>
        </svg>
      </a>
    </div>

    <div class="f2d2-products-page__grid">

      {%- for block in category_blocks -%}

        {%- liquid

          assign collection = block.settings.collection
          assign title = block.settings.title | default: collection.title
          assign description = block.settings.description

          assign image = block.settings.image

          if image == blank and collection != blank

            assign first_product = collection.products.first

            if first_product.featured_media.preview_image != blank
              assign image = first_product.featured_media.preview_image

            elsif first_product.featured_image != blank
              assign image = first_product.featured_image

            elsif collection.image != blank
              assign image = collection.image
            endif

          endif

          assign href = routes.collections_url

          case title

            when 'VÊTEMENTS'
              assign href = '/pages/vetements'

            when 'CHANDAILS À CAPUCHE'
              assign href = '/collections/hoodies'

            when 'CASQUETTES'
              assign href = '/collections/chapeaux'

            when 'BOUTEILLES & CONTENANTS'
              assign href = '/collections/bouteilles-et-contenants'

            when 'SACS & BAGAGES'
              assign href = '/collections/sacs'

            when 'ACCESSOIRES'
              assign href = '/collections/accessoire'

          endcase

        -%}

        <article class="f2d2-category-card" {{ block.shopify_attributes }}>

          <a
            href="{{ href }}"
            class="f2d2-category-card__link"
            aria-label="{{ title | escape }}"
          >

            <div class="f2d2-category-card__media">

              {%- if image != blank -%}

                {{
                  image
                  | image_url: width: 700
                  | image_tag:
                    loading: 'lazy',
                    widths: '220, 360, 520, 700',
                    sizes: '(max-width: 749px) 44vw, (max-width: 1199px) 30vw, 16vw',
                    class: 'f2d2-category-card__image'
                }}

              {%- else -%}

                {{
                  'collection-1'
                  | placeholder_svg_tag: 'f2d2-category-card__placeholder'
                }}

              {%- endif -%}

            </div>

            <span class="f2d2-category-card__icon">

              {%- case block.settings.icon -%}

                {%- when 'shirt' -%}

                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 4 5 5.5 2 9l3 3 2-1v9h10v-9l2 1 3-3-3-3.5L16 4l-4 2-4-2Z"/>
                    <path d="M9 4c.6 1.5 1.6 2.2 3 2.2S14.4 5.5 15 4"/>
                  </svg>

                {%- when 'hoodie' -%}

                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 5c1-1.4 2.3-2 4-2s3 .6 4 2l3 3v12H5V8l3-3Z"/>
                    <path d="M8 5c1.2 1 2.5 1.5 4 1.5S14.8 6 16 5"/>
                    <path d="M9 12v6"/>
                    <path d="M15 12v6"/>
                  </svg>

                {%- when 'cap' -%}

                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M4 14c.8-4.2 3.6-7 8-7s7.2 2.8 8 7H4Z"/>
                    <path d="M4 14c3.8 2.1 8.9 2.4 16 0"/>
                    <path d="M20 14h2"/>
                  </svg>

                {%- when 'bottle' -%}

                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M10 2h4v4l2 3v12H8V9l2-3V2Z"/>
                    <path d="M9 13h6"/>
                    <path d="M10 6h4"/>
                  </svg>

                {%- when 'bag' -%}

                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M6 8h12l1 13H5L6 8Z"/>
                    <path d="M9 8a3 3 0 0 1 6 0"/>
                    <path d="M9 13h6"/>
                  </svg>

                {%- else -%}

                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M7 8h10v12H7z"/>
                    <path d="M17 10h1a3 3 0 0 1 0 6h-1"/>
                  </svg>

              {%- endcase -%}

            </span>

            <div class="f2d2-category-card__content">

              <h2>{{ title | escape }}</h2>

              {%- if description != blank -%}
                <p>{{ description | escape }}</p>
              {%- endif -%}

              <span class="f2d2-category-card__button">

                Voir les produits

                <svg viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M4 10h11"/>
                  <path d="m11 6 4 4-4 4"/>
                </svg>

              </span>

            </div>

          </a>

        </article>

      {%- endfor -%}

    </div>

  </div>
</section>
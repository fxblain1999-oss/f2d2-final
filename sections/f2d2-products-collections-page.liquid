{%- liquid
  assign category_blocks = section.blocks | where: 'type', 'category'
-%}

<section class="f2d2-products-page section-{{ section.id }}">
  <div class="f2d2-products-page__glow" aria-hidden="true"></div>
  <div class="f2d2-products-page__inner page-width">
    <div class="f2d2-products-page__hero">
      {%- if section.settings.eyebrow != blank -%}
        <p class="f2d2-products-page__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1>{{ section.settings.heading | escape }}</h1>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="f2d2-products-page__intro rte">{{ section.settings.text }}</div>
      {%- endif -%}
      <a href="{{ routes.all_products_collection_url }}" class="f2d2-products-page__all-button">
        Tous nos produits
        <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h11"/><path d="m11 6 4 4-4 4"/></svg>
      </a>
    </div>

    <div class="f2d2-products-page__features" aria-label="Avantages">
      <div class="f2d2-feature">
        <span class="f2d2-feature__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3 7 3v5c0 4.5-2.9 8.4-7 10-4.1-1.6-7-5.5-7-10V6l7-3Z"/><path d="m9 12 2 2 4-5"/></svg>
        </span>
        <span><strong>Qualité supérieure</strong><small>Des produits durables et fiables</small></span>
      </div>
      <div class="f2d2-feature">
        <span class="f2d2-feature__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 13 13 20 4 11V4h7l9 9Z"/><path d="M7.5 7.5h.01"/></svg>
        </span>
        <span><strong>Meilleurs prix</strong><small>Prix compétitifs garantis</small></span>
      </div>
      <div class="f2d2-feature">
        <span class="f2d2-feature__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h12v10H3z"/><path d="M15 10h3l3 3v3h-6z"/><path d="M7 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="M17 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/></svg>
        </span>
        <span><strong>Livraison rapide</strong><small>Partout au Canada</small></span>
      </div>
      <div class="f2d2-feature">
        <span class="f2d2-feature__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 13a8 8 0 0 1 16 0"/><path d="M4 13v4a2 2 0 0 0 2 2h1v-8H6a2 2 0 0 0-2 2Z"/><path d="M20 13v4a2 2 0 0 1-2 2h-1v-8h1a2 2 0 0 1 2 2Z"/></svg>
        </span>
        <span><strong>Service client</strong><small>Support dédié 7j/7</small></span>
      </div>
    </div>

    <div class="f2d2-products-page__grid">
      {%- for block in category_blocks -%}
        {%- liquid
          assign collection = block.settings.collection
          assign title = block.settings.title | default: collection.title
          assign description = block.settings.description
          assign image = block.settings.image
          if image == blank and collection != blank
            assign first_product = collection.products.first
            assign image = first_product.featured_media.preview_image
            if image == blank
              assign image = first_product.featured_image
            endif
            if image == blank
              assign image = first_product.images.first
            endif
            if image == blank
              assign image = collection.image
            endif

            assign href = routes.collections_url

            case title
              when 'VÊTEMENTS'
                assign href = '/collections/tous-nos-vetements'

              when 'CHANDAILS À CAPUCHE'
                assign href = '/collections/hoodies'

              when 'CASQUETTES'
                assign href = '/collections/chapeaux'

              when 'BOUTEILLES & CONTENANTS'
                assign href = '/collections/bouteilles-et-contenants'

              when 'SACS & BAGAGES'
                assign href = '/collections/sacs'

              when 'ACCESSOIRES'
                assign href = '/collections/accessoire'
            endcase
        -%}
        <article class="f2d2-category-card" {{ block.shopify_attributes }}>
          <a href="{{ href }}" class="f2d2-category-card__link" aria-label="{{ title | escape }}">
            <div class="f2d2-category-card__media">
              {%- if image != blank -%}
                {{
                  image
                  | image_url: width: 700
                  | image_tag:
                    loading: 'lazy',
                    widths: '220, 360, 520, 700',
                    sizes: '(max-width: 749px) 44vw, (max-width: 1199px) 30vw, 16vw',
                    class: 'f2d2-category-card__image'
                }}
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'f2d2-category-card__placeholder' }}
              {%- endif -%}
            </div>
            <span class="f2d2-category-card__icon">
              {%- case block.settings.icon -%}
                {%- when 'shirt' -%}
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 4 5 5.5 2 9l3 3 2-1v9h10v-9l2 1 3-3-3-3.5L16 4l-4 2-4-2Z"/><path d="M9 4c.6 1.5 1.6 2.2 3 2.2S14.4 5.5 15 4"/></svg>
                {%- when 'hoodie' -%}
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5c1-1.4 2.3-2 4-2s3 .6 4 2l3 3v12H5V8l3-3Z"/><path d="M8 5c1.2 1 2.5 1.5 4 1.5S14.8 6 16 5"/><path d="M9 12v6"/><path d="M15 12v6"/></svg>
                {%- when 'cap' -%}
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 14c.8-4.2 3.6-7 8-7s7.2 2.8 8 7H4Z"/><path d="M4 14c3.8 2.1 8.9 2.4 16 0"/><path d="M20 14h2"/></svg>
                {%- when 'bottle' -%}
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 2h4v4l2 3v12H8V9l2-3V2Z"/><path d="M9 13h6"/><path d="M10 6h4"/></svg>
                {%- when 'bag' -%}
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 8h12l1 13H5L6 8Z"/><path d="M9 8a3 3 0 0 1 6 0"/><path d="M9 13h6"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 8h10v12H7z"/><path d="M17 10h1a3 3 0 0 1 0 6h-1"/></svg>
              {%- endcase -%}
            </span>
            <div class="f2d2-category-card__content">
              <h2>{{ title | escape }}</h2>
              {%- if description != blank -%}
                <p>{{ description | escape }}</p>
              {%- endif -%}
              <span class="f2d2-category-card__button">
                Voir les produits
                <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h11"/><path d="m11 6 4 4-4 4"/></svg>
              </span>
            </div>
          </a>
        </article>
      {%- endfor -%}
    </div>

    <div class="f2d2-products-page__cta-grid">
      <a href="/pages/nos-services" class="f2d2-service-card">
        <span class="f2d2-service-card__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 21V9l8-5 8 5v12"/><path d="M9 21v-7h6v7"/><path d="M8 11h2"/><path d="M14 11h2"/></svg></span>
        <span><strong>Solutions corporatives</strong><small>Des produits personnalisés pour votre entreprise.</small><em>En savoir plus</em></span>
      </a>
      <a href="/pages/nos-services" class="f2d2-service-card">
        <span class="f2d2-service-card__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 20 20 4"/><path d="M7 4h4v4H7z"/><path d="M13 16h4v4h-4z"/><path d="M5 18h4"/><path d="M15 6h4"/></svg></span>
        <span><strong>Personnalisation</strong><small>Ajoutez votre logo et créez des produits uniques.</small><em>Découvrir nos services</em></span>
      </a>
      <a href="/pages/contact" class="f2d2-service-card">
        <span class="f2d2-service-card__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3 8 4v10l-8 4-8-4V7l8-4Z"/><path d="m4 7 8 4 8-4"/><path d="M12 11v10"/></svg></span>
        <span><strong>Commandes en gros</strong><small>Profitez de tarifs avantageux pour vos grosses commandes.</small><em>Demander une soumission</em></span>
      </a>
    </div>

    <div class="f2d2-products-page__stats" aria-label="Statistiques">
      <div><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 14s1.5 2 4 2 4-2 4-2"/><path d="M9 9h.01"/><path d="M15 9h.01"/><circle cx="12" cy="12" r="9"/></svg><strong>5000+</strong><span>Clients satisfaits</span></div>
      <div><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3 2.7 5.5 6.1.9-4.4 4.3 1 6.1L12 17l-5.4 2.8 1-6.1-4.4-4.3 6.1-.9L12 3Z"/></svg><strong>1000+</strong><span>Produits vendus</span></div>
      <div><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3 7 3v5c0 4.5-2.9 8.4-7 10-4.1-1.6-7-5.5-7-10V6l7-3Z"/><path d="m9 12 2 2 4-5"/></svg><strong>Garantie 100%</strong><span>Satisfaction garantie</span></div>
      <div><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 21V4"/><path d="M5 5c5-2 7 3 14 1v10c-7 2-9-3-14-1"/></svg><strong>Entreprise locale</strong><span>Québec, Canada</span></div>
    </div>
  </div>
</section>

{% style %}
  .section-{{ section.id }} {
    --f2d2-blue: #0f7cff;
    --f2d2-blue-deep: #0047b7;
    --f2d2-surface: rgba(255, 255, 255, 0.055);
    --f2d2-border: rgba(255, 255, 255, 0.16);
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    padding: 5.6rem 0 4.2rem;
    color: #fff;
    background:
      radial-gradient(circle at 50% 0%, rgba(0, 92, 214, 0.3), transparent 35rem),
      radial-gradient(circle at 8% 45%, rgba(0, 129, 255, 0.14), transparent 24rem),
      linear-gradient(135deg, #050b0f 0%, #071017 46%, #020507 100%);
  }

  .section-{{ section.id }} .f2d2-products-page__glow {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.4), transparent 70%);
    pointer-events: none;
  }

  .section-{{ section.id }} .f2d2-products-page__inner {
    position: relative;
    z-index: 1;
  }

  .section-{{ section.id }} .f2d2-products-page__hero {
    max-width: 74rem;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .section-{{ section.id }} .f2d2-products-page__eyebrow {
    margin: 0 0 1.1rem;
    color: #28a5ff;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-{{ section.id }} h1 {
    margin: 0;
    color: #fff;
    font-size: clamp(3.4rem, 5vw, 5.8rem);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .section-{{ section.id }} .f2d2-products-page__intro {
    max-width: 58rem;
    margin: 2rem auto 0;
    color: rgba(255, 255, 255, 0.76);
    font-size: 1.8rem;
    line-height: 1.55;
  }

  .section-{{ section.id }} .f2d2-products-page__all-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    min-height: 4.8rem;
    margin-top: 2.6rem;
    padding: 1.2rem 2.6rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 99rem;
    color: #fff;
    background: linear-gradient(145deg, var(--f2d2-blue), var(--f2d2-blue-deep));
    box-shadow: 0 1.2rem 3rem rgba(0, 91, 255, 0.28);
    font-size: 1.45rem;
    font-weight: 800;
    text-decoration: none;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .section-{{ section.id }} .f2d2-products-page__all-button:hover {
    transform: translateY(-0.2rem);
    box-shadow: 0 1.6rem 3.6rem rgba(0, 91, 255, 0.36);
  }

  .section-{{ section.id }} .f2d2-products-page__all-button svg {
    width: 1.9rem;
    height: 1.9rem;
  }

  .section-{{ section.id }} .f2d2-products-page__features {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2.4rem;
    max-width: 104rem;
    margin: 0 auto 3.6rem;
  }

  .section-{{ section.id }} .f2d2-feature {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    min-width: 0;
    padding-inline: 2rem;
    border-right: 1px solid rgba(255, 255, 255, 0.14);
  }

  .section-{{ section.id }} .f2d2-feature:last-child {
    border-right: 0;
  }

  .section-{{ section.id }} .f2d2-feature__icon,
  .section-{{ section.id }} .f2d2-category-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    color: #fff;
    background: linear-gradient(145deg, var(--f2d2-blue), var(--f2d2-blue-deep));
    box-shadow: 0 1.2rem 3.5rem rgba(0, 91, 255, 0.34);
  }

  .section-{{ section.id }} svg {
    width: 2.4rem;
    height: 2.4rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .section-{{ section.id }} .f2d2-feature__icon {
    width: 4.8rem;
    height: 4.8rem;
    border-radius: 50%;
    color: #5fb1ff;
    background: rgba(0, 96, 255, 0.12);
  }

  .section-{{ section.id }} .f2d2-feature strong,
  .section-{{ section.id }} .f2d2-feature small {
    display: block;
  }

  .section-{{ section.id }} .f2d2-feature strong {
    color: #fff;
    font-size: 1.5rem;
  }

  .section-{{ section.id }} .f2d2-feature small {
    margin-top: 0.3rem;
    color: rgba(255, 255, 255, 0.62);
    font-size: 1.35rem;
  }

  .section-{{ section.id }} .f2d2-products-page__grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 1.6rem;
  }

  .section-{{ section.id }} .f2d2-category-card {
    min-width: 0;
    border: 1px solid var(--f2d2-border);
    border-radius: 0.8rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.025)),
      rgba(5, 10, 14, 0.82);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .section-{{ section.id }} .f2d2-category-card:hover {
    transform: translateY(-0.4rem);
    border-color: rgba(69, 158, 255, 0.7);
    background:
      linear-gradient(180deg, rgba(14, 124, 255, 0.13), rgba(255, 255, 255, 0.035)),
      rgba(5, 10, 14, 0.88);
  }

  .section-{{ section.id }} .f2d2-category-card__link {
    display: flex;
    flex-direction: column;
    min-height: 38.4rem;
    height: 100%;
    padding: 1.8rem 1.8rem 1.6rem;
    color: inherit;
    text-align: center;
    text-decoration: none;
  }

  .section-{{ section.id }} .f2d2-category-card__media {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 20.4rem;
    margin-bottom: -0.6rem;
    overflow: hidden;
  }

  .section-{{ section.id }} .f2d2-category-card__image,
  .section-{{ section.id }} .f2d2-category-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 2rem 2.4rem rgba(0, 0, 0, 0.5));
    transform: scale(1.02);
  }

  .section-{{ section.id }} .f2d2-category-card__placeholder {
    opacity: 0.5;
  }

  .section-{{ section.id }} .f2d2-category-card__icon {
    width: 6.8rem;
    height: 6.8rem;
    margin: 0 auto 1.1rem;
    border-radius: 50%;
  }

  .section-{{ section.id }} .f2d2-category-card__content {
    display: flex;
    flex: 1;
    flex-direction: column;
    align-items: center;
  }

  .section-{{ section.id }} .f2d2-category-card h2 {
    margin: 0;
    color: #fff;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .section-{{ section.id }} .f2d2-category-card p {
    margin: 0.8rem 0 1.4rem;
    color: rgba(255, 255, 255, 0.66);
    font-size: 1.35rem;
    line-height: 1.35;
  }

  .section-{{ section.id }} .f2d2-category-card__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    width: 100%;
    max-width: 19.5rem;
    min-height: 4.2rem;
    margin-top: auto;
    padding: 0.9rem 1.6rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 99rem;
    color: #fff;
    background: rgba(255, 255, 255, 0.04);
    font-size: 1.3rem;
    font-weight: 700;
  }

  .section-{{ section.id }} .f2d2-category-card__button svg {
    width: 1.8rem;
    height: 1.8rem;
  }

  .section-{{ section.id }} .f2d2-products-page__cta-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.8rem;
    margin-top: 3rem;
  }

  .section-{{ section.id }} .f2d2-service-card {
    display: flex;
    gap: 2rem;
    align-items: center;
    min-height: 11.4rem;
    padding: 2.2rem 2.4rem;
    border-radius: 0.8rem;
    color: inherit;
    text-decoration: none;
    background: linear-gradient(135deg, rgba(22, 74, 139, 0.82), rgba(6, 29, 58, 0.95));
  }

  .section-{{ section.id }} .f2d2-service-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 6.2rem;
    height: 6.2rem;
    flex: 0 0 auto;
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.1);
  }

  .section-{{ section.id }} .f2d2-service-card strong,
  .section-{{ section.id }} .f2d2-service-card small,
  .section-{{ section.id }} .f2d2-service-card em {
    display: block;
  }

  .section-{{ section.id }} .f2d2-service-card strong {
    color: #fff;
    font-size: 1.8rem;
  }

  .section-{{ section.id }} .f2d2-service-card small {
    margin-top: 0.5rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 1.35rem;
    line-height: 1.4;
  }

  .section-{{ section.id }} .f2d2-service-card em {
    margin-top: 1.1rem;
    color: #67b8ff;
    font-style: normal;
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }

  .section-{{ section.id }} .f2d2-service-card em::after {
    content: " ->";
    text-decoration: none;
  }

  .section-{{ section.id }} .f2d2-products-page__stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2rem;
    max-width: 108rem;
    margin: 3.8rem auto 0;
  }

  .section-{{ section.id }} .f2d2-products-page__stats > div {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 1.4rem;
    align-items: center;
    padding-inline: 2.4rem;
    border-right: 1px solid rgba(255, 255, 255, 0.14);
  }

  .section-{{ section.id }} .f2d2-products-page__stats > div:last-child {
    border-right: 0;
  }

  .section-{{ section.id }} .f2d2-products-page__stats svg {
    grid-row: span 2;
    width: 4.2rem;
    height: 4.2rem;
    color: #2d8fff;
  }

  .section-{{ section.id }} .f2d2-products-page__stats strong {
    color: #fff;
    font-size: 2rem;
    line-height: 1.15;
  }

  .section-{{ section.id }} .f2d2-products-page__stats span {
    color: rgba(255, 255, 255, 0.64);
    font-size: 1.45rem;
  }

  @media (max-width: 1199px) {
    .section-{{ section.id }} .f2d2-products-page__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .section-{{ section.id }} .f2d2-products-page__features,
    .section-{{ section.id }} .f2d2-products-page__stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .section-{{ section.id }} .f2d2-feature:nth-child(2),
    .section-{{ section.id }} .f2d2-products-page__stats > div:nth-child(2) {
      border-right: 0;
    }
  }

  @media (max-width: 899px) {
    .section-{{ section.id }} {
      padding-top: 4.4rem;
    }

    .section-{{ section.id }} .f2d2-products-page__features,
    .section-{{ section.id }} .f2d2-products-page__cta-grid,
    .section-{{ section.id }} .f2d2-products-page__stats {
      grid-template-columns: 1fr;
    }

    .section-{{ section.id }} .f2d2-feature,
    .section-{{ section.id }} .f2d2-products-page__stats > div {
      border-right: 0;
      padding-inline: 0;
    }
  }

  @media (max-width: 749px) {
    .section-{{ section.id }} h1 {
      font-size: 3.7rem;
    }

    .section-{{ section.id }} .f2d2-products-page__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.2rem;
    }

    .section-{{ section.id }} .f2d2-category-card__link {
      min-height: 31rem;
      padding: 1.2rem;
    }

    .section-{{ section.id }} .f2d2-category-card__media {
      height: 14rem;
    }

    .section-{{ section.id }} .f2d2-category-card__icon {

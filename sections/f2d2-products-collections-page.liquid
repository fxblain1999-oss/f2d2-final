<script>
  (() => {
    const section = document.querySelector('.section-{{ section.id }}');
    if (!section) return;

    const titles = Array.from(section.querySelectorAll('[data-f2d2-fit-title]'));
    if (!titles.length) return;

    const lineHeightFor = (element) => {
      const styles = window.getComputedStyle(element);
      const fontSize = parseFloat(styles.fontSize) || 16;
      const lineHeight = parseFloat(styles.lineHeight);
      return Number.isFinite(lineHeight) ? lineHeight : fontSize * 1.08;
    };

    const fitsInTwoLines = (element) => {
      const lineHeight = lineHeightFor(element);
      return element.scrollHeight <= lineHeight * 2 + 2;
    };

    const fitTitle = (element) => {
      element.style.fontSize = '';
      const styles = window.getComputedStyle(element);
      const maxSize = parseFloat(styles.fontSize) || 16;
      const minSize = parseFloat(element.dataset.f2d2FitMin) || Math.max(maxSize * 0.72, 12);
      let nextSize = maxSize;

      while (!fitsInTwoLines(element) && nextSize > minSize) {
        nextSize -= 0.5;
        element.style.fontSize = `${nextSize}px`;
      }
    };

    let frame = null;
    const fitAllTitles = () => {
      if (frame) window.cancelAnimationFrame(frame);
      frame = window.requestAnimationFrame(() => {
        titles.forEach(fitTitle);
      });
    };

    fitAllTitles();
    window.addEventListener('resize', fitAllTitles, { passive: true });

    if ('ResizeObserver' in window) {
      const observer = new ResizeObserver(fitAllTitles);
      observer.observe(section);
    }

    document.addEventListener('shopify:section:load', fitAllTitles);
  })();
</script>


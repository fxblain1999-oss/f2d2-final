{%- if collection.handle == 'design-f2d2' -%}
  {%- liquid
    assign hero_image = 'f2d2-realizations-hero-wide.png' | asset_url
    assign merch_image = 'f2d2-hero-merch.png' | asset_url
    assign web_image = 'f2d2-web-hero-crop.png' | asset_url
    assign logo_image = 'logo_f2d2.png' | asset_url
  -%}

  <section class="f2d2-realizations section-{{ section.id }}">
    <div class="f2d2-realizations__hero">
      <div class="f2d2-realizations__hero-media" aria-hidden="true">
        <img
          src="{{ 'f2d2-realizations-hero-wide.png' | asset_url }}"
          alt=""
          class="f2d2-realizations__hero-image"
          loading="eager"
          width="1922"
          height="818"
        >
      </div>
      <div class="f2d2-realizations__wrap f2d2-realizations__hero-inner">
        <div class="f2d2-realizations__hero-copy">
          <p class="f2d2-realizations__eyebrow">Des idees. Du style. Du resultat.</p>
          <h1><span>Nos</span><span>projets</span><span>realises</span></h1>
          <p>
            Decouvrez quelques projets realises pour nos clients : vetements,
            impression, accessoires promotionnels et branding personnalise.
          </p>
          <div class="f2d2-realizations__actions">
            <a href="#gallery" class="f2d2-realizations__button" data-f2d2-gallery-link>
              Voir nos projets
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h11"/><path d="m11 6 4 4-4 4"/></svg>
            </a>
            <a href="#avis-google" class="f2d2-realizations__button f2d2-realizations__button--ghost">
              Nos avis Google
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h11"/><path d="m11 6 4 4-4 4"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="f2d2-realizations__wrap">
      <section id="projets" class="f2d2-realizations__section">
        <div class="f2d2-realizations__section-head">
          <h2>Projets en vedette</h2>
          <a href="#gallery">Voir tous les projets <span aria-hidden="true">-></span></a>
        </div>
        <div class="f2d2-realizations__featured">
          <article class="f2d2-realizations__project f2d2-realizations__project--wide">
            <div class="f2d2-realizations__project-image f2d2-realizations__project-image--merch"></div>
            <div class="f2d2-realizations__project-copy">
              <small>Restaurant</small>
              <h3>Branding complet</h3>
              <p>Uniformes, menus et affichage complet pour une image de marque professionnelle.</p>
              <a href="/pages/contact">Voir le projet <span aria-hidden="true">-></span></a>
            </div>
          </article>
          <article class="f2d2-realizations__project">
            <div class="f2d2-realizations__project-image f2d2-realizations__project-image--web"></div>
            <div class="f2d2-realizations__project-copy">
              <small>Equipe sportive</small>
              <h3>Collection personnalisee</h3>
              <p>Chandails, hoodies et accessoires personnalises pour une equipe qui se demarque.</p>
              <a href="/pages/contact">Voir le projet <span aria-hidden="true">-></span></a>
            </div>
          </article>
        </div>
      </section>

      <section id="gallery" class="f2d2-realizations__section" data-f2d2-gallery-section>
        <div class="f2d2-realizations__section-head">
          <h2>Galerie de realisations</h2>
        </div>
        <div class="f2d2-realizations__filters" aria-label="Filtres de galerie">
          <button type="button" class="is-active">Tous</button>
          <button type="button">Vetements</button>
          <button type="button">Stickers & impressions</button>
          <button type="button">Accessoires</button>
          <button type="button">Signalisation</button>
          <button type="button">Evenementiel</button>
        </div>
        <div class="f2d2-realizations__gallery-shell" data-f2d2-gallery-shell>
          <button type="button" class="f2d2-realizations__gallery-arrow f2d2-realizations__gallery-arrow--prev" data-f2d2-gallery-prev aria-label="Projets precedents">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <div class="f2d2-realizations__gallery" data-f2d2-gallery>
            {%- for i in (1..10) -%}
              {%- liquid
                assign mod = i | modulo: 3
                assign image_class = 'f2d2-realizations__tile-image--hero'
                if mod == 1
                  assign image_class = 'f2d2-realizations__tile-image--merch'
                elsif mod == 2
                  assign image_class = 'f2d2-realizations__tile-image--web'
                endif
              -%}
              <button type="button" class="f2d2-realizations__tile" aria-label="Realisation F2D2 {{ i }}">
                <span class="f2d2-realizations__tile-image {{ image_class }}"></span>
                <span class="f2d2-realizations__tile-logo" aria-hidden="true"><img src="{{ logo_image }}" width="160" height="62" alt="" loading="lazy"></span>
              </button>
            {%- endfor -%}
          </div>
          <button type="button" class="f2d2-realizations__gallery-arrow f2d2-realizations__gallery-arrow--next" data-f2d2-gallery-next aria-label="Projets suivants">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
        <div class="f2d2-realizations__load">
          <a href="/pages/contact" class="f2d2-realizations__button f2d2-realizations__button--small f2d2-realizations__button--ghost">
            Charger plus de projets
            <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 4v12"/><path d="M4 10h12"/></svg>
          </a>
        </div>
      </section>

      <section class="f2d2-realizations__section">
        <div class="f2d2-realizations__section-head">
          <h2>Categories de realisations</h2>
          <a href="{{ routes.collections_url }}">Voir toutes <span aria-hidden="true">-></span></a>
        </div>
        <div class="f2d2-realizations__categories">
          <article>
            <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 4 12 6l4-2 4 4-3 3v9H7v-9L4 8l4-4Z"/><path d="M10 5c.5 1.3 3.5 1.3 4 0"/></svg></span>
            <h3>Vetements personnalises</h3>
            <p>T-shirts, hoodies et uniformes.</p>
          </article>
          <article>
            <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 13 13 20 4 11V4h7l9 9Z"/><path d="M7.5 7.5h.01"/></svg></span>
            <h3>Stickers UV DTF</h3>
            <p>Impression durable et branding premium.</p>
          </article>
          <article>
            <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 20V5l6 3 4-3 6 3v15l-6-3-4 3-6-3Z"/><path d="M10 8v15"/><path d="M14 5v15"/></svg></span>
            <h3>Signalisation & bannieres</h3>
            <p>Affichage commercial et evenementiel.</p>
          </article>
          <article>
            <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 10h10l1 11H6l1-11Z"/><path d="M9 10V7a3 3 0 0 1 6 0v3"/></svg></span>
            <h3>Accessoires promotionnels</h3>
            <p>Objets corporatifs et goodies.</p>
          </article>
          <article>
            <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3c3 3 6 5 6 10a6 6 0 0 1-12 0c0-5 3-7 6-10Z"/><path d="M9 14c1.5 1 4.5 1 6 0"/></svg></span>
            <h3>Broderie personnalisee</h3>
            <p>Finition haut de gamme durable.</p>
          </article>
          <article>
            <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"/><path d="M17 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"/><path d="M3 21v-2a4 4 0 0 1 8 0v2"/><path d="M13 21v-2a4 4 0 0 1 8 0v2"/></svg></span>
            <h3>Projets evenementiels</h3>
            <p>Kiosques, festivals et evenements.</p>
          </article>
        </div>
      </section>

      <section class="f2d2-realizations__section">
        <div class="f2d2-realizations__section-head">
          <h2>Avant / apres</h2>
          <a href="/pages/contact">Voir plus <span aria-hidden="true">-></span></a>
        </div>
        <div class="f2d2-realizations__before">
          <article>
            <div class="f2d2-realizations__before-image f2d2-realizations__before-image--vehicle">
              <span>Avant</span><span>Apres</span>
            </div>
            <h3>Lettrage de vehicule</h3>
            <p>Design complet et installation professionnelle.</p>
          </article>
          <article>
            <div class="f2d2-realizations__before-image f2d2-realizations__before-image--dtf">
              <span>Avant</span><span>Apres</span>
            </div>
            <h3>Impression DTF</h3>
            <p>Qualite d'impression superieure et durable.</p>
          </article>
          <article>
            <div class="f2d2-realizations__before-image f2d2-realizations__before-image--bottle">
              <span>Avant</span><span>Apres</span>
            </div>
            <h3>Bouteille personnalisee</h3>
            <p>Votre logo, votre style.</p>
          </article>
        </div>
      </section>

    <section id="avis-google" class="f2d2-realizations__section">
      <div class="f2d2-realizations__section-head">
        <h2>Découvrez ce que nos clients disent de nous sur Google :</h2>
      </div>

      <div class="f2d2-realizations__reviews">

        <a 
          href="https://maps.app.goo.gl/K6L5d6s5efUHFzQo6"
          target="_blank"
          rel="noopener noreferrer"
          class="f2d2-review-link"
        >
          <blockquote>
            <div>&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p>Nos chandails sont superbes!!! On les adore, merci!!!</p>
            <cite>- Vanessa D.<span>Entrepreneur</span></cite>
          </blockquote>
        </a>

        <a 
          href="https://maps.app.goo.gl/Fx3yTZutDTcCSZQp7"
          target="_blank"
          rel="noopener noreferrer"
          class="f2d2-review-link"
        >
          <blockquote>
            <div>&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p>Super produit, rapidité +++ service impeccable</p>
            <cite>- Jay N.<span>Entrepreneur</span></cite>
          </blockquote>
        </a>

        <a 
          href="https://maps.app.goo.gl/wVEtjDncpn58efGR6"
          target="_blank"
          rel="noopener noreferrer"
          class="f2d2-review-link"
        >
          <blockquote>
            <div>&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p>Une équipe de feu, une qualité incroyable et une belle ambiance!</p>
            <cite>- Ohayon C.<span>Entrepreneur</span></cite>
          </blockquote>
        </a>

      </div>
    </section>

      <section class="f2d2-realizations__cta">
        <div>
          <h2>Pret a lancer votre projet?</h2>
          <p>Parlez-nous de votre idee et obtenez une soumission rapide et gratuite.</p>
        </div>
        <div class="f2d2-realizations__actions">
          <a href="/pages/contact" class="f2d2-realizations__button">Demander une soumission <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h11"/><path d="m11 6 4 4-4 4"/></svg></a>
          <a href="/pages/contact" class="f2d2-realizations__button f2d2-realizations__button--ghost">Nous contacter <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h11"/><path d="m11 6 4 4-4 4"/></svg></a>
        </div>
      </section>
    </div>
  </section>

  <style>
    html {
      scroll-behavior: smooth;
    }

    .section-{{ section.id }} {
      --f2d2-blue: #1084ff;
      --f2d2-blue-soft: rgba(16, 132, 255, 0.2);
      --f2d2-line: rgba(255, 255, 255, 0.14);
      --f2d2-text: rgba(255, 255, 255, 0.76);
      color: #fff;
      background:
        radial-gradient(circle at 75% 8rem, rgba(16, 132, 255, 0.16), transparent 34rem),
        linear-gradient(180deg, #020609 0%, #041019 48%, #020609 100%);
      overflow: hidden;
      scroll-behavior: smooth;
    }

    .section-{{ section.id }} * {
      box-sizing: border-box;
      letter-spacing: 0;
    }

    .section-{{ section.id }} .f2d2-realizations__wrap {
      width: min(100% - 4rem, 134rem);
      margin: 0 auto;
    }

    .f2d2-realizations__hero {
      position: relative;
      min-height: 55rem;
      width: 100%;
      overflow: hidden;
      display: flex;
      align-items: center;
    }

    .section-{{ section.id }} .f2d2-realizations__reviews {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.4rem;
      align-items: stretch;
    }

    .section-{{ section.id }} .f2d2-realizations__reviews blockquote {
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .f2d2-realizations__hero-media {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
    }

    .f2d2-realizations__hero-image {
      width: 100%;
      height: 100%;

      min-width: 100%;
      min-height: 100%;

      transform:
        translate(0%, 0%)
        scale(1.2)
        translateX(0%)
        translateY(10%);

      object-fit: cover;
    }

    .f2d2-realizations__hero-media::after {
      content: "";
      position: absolute;
      inset: 0;

      background:
        linear-gradient(
          90deg,
          rgba(2,6,9,0.72) 0%,
          rgba(2,6,9,0.45) 34%,
          rgba(2,6,9,0.08) 72%,
          rgba(2,6,9,0.16) 100%
        );
    }

    .section-{{ section.id }} .f2d2-realizations__hero-inner {
      position: relative;
      z-index: 2;
    }

    .section-{{ section.id }} .f2d2-realizations__hero-copy {
      max-width: 54rem;
      padding: 8rem 0;
    }

    .section-{{ section.id }} .f2d2-realizations__eyebrow {
      margin: 0 0 1rem;
      color: rgba(255, 255, 255, 0.7);
      font-size: 1.2rem;
      font-weight: 800;
      text-transform: uppercase;
    }

    .section-{{ section.id }} h1,
    .section-{{ section.id }} h2,
    .section-{{ section.id }} h3,
    .section-{{ section.id }} p {
      margin: 0;
    }

    .section-{{ section.id }} h1 {
      max-width: 78rem;
      font-size: clamp(5.2rem, 7vw, 10.2rem);
      line-height: 0.84;
      font-weight: 900;
      text-transform: uppercase;
    }

    .section-{{ section.id }} h1 span {
      display: block;
    }

    .section-{{ section.id }} h1 span:nth-child(2),
    .section-{{ section.id }} h1 span:nth-child(3) {
      color: var(--f2d2-blue);
      font-style: italic;
    }

    .section-{{ section.id }} .f2d2-realizations__hero-copy > p:not(.f2d2-realizations__eyebrow) {
      max-width: 42rem;
      margin-top: 2.2rem;
      color: var(--f2d2-text);
      font-size: 1.6rem;
      line-height: 1.55;
    }

    .section-{{ section.id }} .f2d2-realizations__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1.2rem;
      margin-top: 2.8rem;
    }

    .section-{{ section.id }} .f2d2-realizations__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      min-height: 5.2rem;
      padding: 0 2.6rem;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 0.4rem;
      color: #fff;
      background: linear-gradient(135deg, #0067d9, var(--f2d2-blue));
      font-size: 1.25rem;
      font-weight: 900;
      text-transform: uppercase;
      text-decoration: none;
      transition: transform 180ms ease, border-color 180ms ease;
    }

    .section-{{ section.id }} .f2d2-realizations__button:hover {
      transform: translateY(-0.2rem);
      border-color: rgba(255, 255, 255, 0.38);
    }

    .section-{{ section.id }} .f2d2-realizations__button--ghost {
      background: rgba(0, 0, 0, 0.28);
    }

    .section-{{ section.id }} .f2d2-realizations__button--small {
      min-height: 4.2rem;
      padding: 0 2rem;
      font-size: 1.15rem;
    }

    .section-{{ section.id }} .f2d2-realizations__button svg,
    .section-{{ section.id }} a svg {
      width: 1.8rem;
      height: 1.8rem;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .section-{{ section.id }} .f2d2-realizations__section {
      padding: 3.8rem 0 0;
    }

    .section-{{ section.id }} #gallery {
      scroll-margin-top: 30px;
      height: 100svh;
      min-height: 76rem;
      display: flex;
      flex-direction: column;
      width: 100vw;
      margin-left: calc(50% - 50vw);
      padding: 4.8rem max(2rem, calc((100vw - 134rem) / 2)) 4.4rem;
      background:
        radial-gradient(circle at 50% 18%, rgba(16, 132, 255, 0.14), transparent 38rem),
        linear-gradient(180deg, rgba(2, 6, 9, 0.2), rgba(2, 6, 9, 0.7));
    }

    .section-{{ section.id }} .f2d2-realizations__section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.6rem;
      margin-bottom: 1.8rem;
    }

    .section-{{ section.id }} .f2d2-realizations__section-head h2 {
      font-size: clamp(2rem, 2.2vw, 2.8rem);
      font-weight: 900;
      text-transform: uppercase;
    }

    .section-{{ section.id }} .f2d2-realizations__section-head a,
    .section-{{ section.id }} .f2d2-realizations__project-copy a {
      color: #39a4ff;
      font-size: 1.25rem;
      font-weight: 800;
      text-decoration: none;
    }

    .section-{{ section.id }} .f2d2-realizations__featured {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.8rem;
    }

    .section-{{ section.id }} .f2d2-realizations__project,
    .section-{{ section.id }} .f2d2-realizations__categories article,
    .section-{{ section.id }} .f2d2-realizations__before article,
    .section-{{ section.id }} .f2d2-realizations__reviews blockquote {
      position: relative;
      min-height: 28rem;
      overflow: hidden;
      border: 1px solid var(--f2d2-line);
      border-radius: 0.8rem;
      background: rgba(255, 255, 255, 0.045);
    }

    .section-{{ section.id }} .f2d2-realizations__project-image,
    .section-{{ section.id }} .f2d2-realizations__tile-image,
    .section-{{ section.id }} .f2d2-realizations__before-image {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      transform: scale(1.01);
    }

    .section-{{ section.id }} .f2d2-realizations__project-image::after,
    .section-{{ section.id }} .f2d2-realizations__tile-image::after,
    .section-{{ section.id }} .f2d2-realizations__before-image::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(2, 6, 9, 0.88), rgba(2, 6, 9, 0.24) 72%);
    }

    .section-{{ section.id }} .f2d2-realizations__project-image--merch,
    .section-{{ section.id }} .f2d2-realizations__tile-image--merch,
    .section-{{ section.id }} .f2d2-realizations__before-image--dtf {
      background-image: url({{ merch_image }});
    }

    .section-{{ section.id }} .f2d2-realizations__project-image--web,
    .section-{{ section.id }} .f2d2-realizations__tile-image--web,
    .section-{{ section.id }} .f2d2-realizations__before-image--vehicle {
      background-image: url({{ web_image }});
    }

    .section-{{ section.id }} .f2d2-realizations__tile-image--hero,
    .section-{{ section.id }} .f2d2-realizations__before-image--bottle {
      background-image: url({{ hero_image }});
    }

    .section-{{ section.id }} .f2d2-realizations__project-copy {
      position: relative;
      z-index: 1;
      max-width: 36rem;
      padding: 5rem 3.2rem;
    }

    .section-{{ section.id }} .f2d2-realizations__project-copy small {
      color: rgba(255, 255, 255, 0.78);
      font-size: 1.05rem;
      font-weight: 900;
      text-transform: uppercase;
    }

    .section-{{ section.id }} .f2d2-realizations__project-copy h3 {
      margin-top: 1rem;
      font-size: clamp(2.4rem, 3vw, 4rem);
      line-height: 0.98;
      font-weight: 900;
      text-transform: uppercase;
    }

    .section-{{ section.id }} .f2d2-realizations__project-copy p {
      margin-top: 2rem;
      color: var(--f2d2-text);
      font-size: 1.35rem;
      line-height: 1.5;
    }

    .section-{{ section.id }} .f2d2-realizations__project-copy a {
      display: inline-block;
      margin-top: 3rem;
    }

    .section-{{ section.id }} .f2d2-realizations__filters {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1.8rem;
    }

    .section-{{ section.id }} .f2d2-realizations__filters button {
      min-height: 3.8rem;
      padding: 0 1.8rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 999px;
      color: rgba(255, 255, 255, 0.78);
      background: rgba(255, 255, 255, 0.06);
      font-size: 1.2rem;
      font-weight: 800;
      cursor: pointer;
    }

    .section-{{ section.id }} .f2d2-realizations__filters button.is-active {
      color: #fff;
      background: var(--f2d2-blue);
    }

    .section-{{ section.id }} .f2d2-realizations__gallery-shell {
      position: relative;
      flex: 1 1 auto;
      min-height: 0;
    }

    .section-{{ section.id }} .f2d2-realizations__gallery {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      grid-template-rows: repeat(2, minmax(0, 1fr));
      align-items: stretch;
      gap: 1.4rem;
      height: 100%;
      min-height: 0;
    }

    .section-{{ section.id }} .f2d2-realizations__tile {
      position: relative;
      display: block;
      width: 100%;
      height: 100%;
      min-height: 0;
      overflow: hidden;
      border: 1px solid var(--f2d2-line);
      border-radius: 0.8rem;
      background: rgba(255, 255, 255, 0.045);
      cursor: pointer;
    }

    .section-{{ section.id }} .f2d2-realizations__tile.is-hidden {

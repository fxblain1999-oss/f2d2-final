      }

      .section-{{ section.id }} .f2d2-realizations__categories article {
        padding: 2.2rem 1.2rem;
      }
    }
  </style>

  <script>
    (() => {
      const section = document.querySelector('.section-{{ section.id }}');
      if (!section) return;

      const shell = section.querySelector('[data-f2d2-gallery-shell]');
      const gallery = section.querySelector('[data-f2d2-gallery]');
      const prev = section.querySelector('[data-f2d2-gallery-prev]');
      const next = section.querySelector('[data-f2d2-gallery-next]');
      if (!shell || !gallery || !prev || !next) return;

      const tiles = Array.from(gallery.querySelectorAll('.f2d2-realizations__tile'));
      let currentPage = 0;
      let touchStartX = 0;

      const pageSizeForViewport = () => {
        if (window.matchMedia('(max-width: 560px)').matches) return 4;
        if (window.matchMedia('(max-width: 989px)').matches) return 6;
        return 10;
      };

      const updateGallery = () => {
        const pageSize = pageSizeForViewport();
        const pageCount = Math.max(Math.ceil(tiles.length / pageSize), 1);
        currentPage = Math.min(currentPage, pageCount - 1);

        tiles.forEach((tile, index) => {
          const isVisible = index >= currentPage * pageSize && index < (currentPage + 1) * pageSize;
          tile.classList.toggle('is-hidden', !isVisible);
          tile.setAttribute('aria-hidden', isVisible ? 'false' : 'true');
          tile.tabIndex = isVisible ? 0 : -1;
        });

        const hasPages = pageCount > 1;
        prev.hidden = !hasPages;
        next.hidden = !hasPages;
        prev.disabled = currentPage === 0;
        next.disabled = currentPage >= pageCount - 1;
      };

      const goToPage = (direction) => {
        currentPage += direction;
        updateGallery();
      };

      prev.addEventListener('click', () => goToPage(-1));
      next.addEventListener('click', () => goToPage(1));

      shell.addEventListener('touchstart', (event) => {
        touchStartX = event.touches[0].clientX;
      }, { passive: true });

      shell.addEventListener('touchend', (event) => {
        const touchEndX = event.changedTouches[0].clientX;
        const delta = touchEndX - touchStartX;
        if (Math.abs(delta) < 48) return;
        goToPage(delta < 0 ? 1 : -1);
      }, { passive: true });

      updateGallery();
      window.addEventListener('resize', updateGallery, { passive: true });
    })();
  </script>

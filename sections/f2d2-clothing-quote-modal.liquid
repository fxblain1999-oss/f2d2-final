{% liquid
  assign modal_id = 'f2d2-clothing-quote-modal'
%}

<div id="{{ modal_id }}" class="f2d2-clothing-quote-modal" role="dialog" aria-modal="true" aria-labelledby="f2d2-clothing-quote-title" hidden>
  <div class="f2d2-clothing-quote-modal__overlay" data-f2d2-clothing-quote-close></div>

  <div class="f2d2-clothing-quote-modal__panel" tabindex="-1">
    <button type="button" class="f2d2-clothing-quote-modal__close" aria-label="Fermer" data-f2d2-clothing-quote-close>
      &times;
    </button>

    <div class="f2d2-clothing-quote-modal__head">
      <p class="f2d2-clothing-quote-modal__eyebrow">Soumission F2D2</p>
      <h2 id="f2d2-clothing-quote-title">Parlez-nous de votre projet</h2>
      <p>Plus les details sont clairs, plus la soumission sera rapide et precise.</p>
    </div>

    {% form 'contact', id: 'f2d2-clothing-quote-form', class: 'f2d2-clothing-quote-modal__form' %}
      {% if form.posted_successfully? %}
        <div class="f2d2-clothing-quote-modal__status f2d2-clothing-quote-modal__status--success" role="status">
          Merci. Votre demande de soumission a bien ete envoyee.
        </div>
      {% elsif form.errors %}
        <div class="f2d2-clothing-quote-modal__status f2d2-clothing-quote-modal__status--error" role="alert">
          Verifiez les champs requis, puis reessayez.
        </div>
      {% endif %}

      <input type="hidden" name="contact[Type de demande]" value="Soumission vetements et produits">

      <div class="f2d2-clothing-quote-modal__grid">
        <label>
          <span>Nom complet *</span>
          <input type="text" name="contact[Nom]" autocomplete="name" required>
        </label>

        <label>
          <span>Courriel *</span>
          <input type="email" name="contact[email]" autocomplete="email" required>
        </label>

        <label>
          <span>Telephone *</span>
          <input type="tel" name="contact[Telephone]" autocomplete="tel" required>
        </label>

        <label>
          <span>Entreprise</span>
          <input type="text" name="contact[Entreprise]" autocomplete="organization">
        </label>

        <label>
          <span>Type de projet *</span>
          <select name="contact[Type de projet]" required>
            <option value="">Selectionnez</option>
            <option value="DTF">DTF</option>
            <option value="UV DTF">UV DTF</option>
            <option value="Gravure">Gravure</option>
            <option value="Corporatif">Corporatif</option>
            <option value="Vetements personnalises">Vetements personnalises</option>
            <option value="Autre">Autre</option>
          </select>
        </label>

        <label>
          <span>Quantite approximative</span>
          <input type="text" name="contact[Quantite]" placeholder="Ex: 50 chandails, 100 collants">
        </label>

        <label>
          <span>Date souhaitee</span>
          <input type="text" name="contact[Date souhaitee]" placeholder="Ex: semaine prochaine">
        </label>

        <label>
          <span>Budget</span>
          <select name="contact[Budget]">
            <option value="">A determiner</option>
            <option value="Moins de 250$">Moins de 250$</option>
            <option value="250$ a 500$">250$ a 500$</option>
            <option value="500$ a 1000$">500$ a 1000$</option>
            <option value="1000$ et plus">1000$ et plus</option>
          </select>
        </label>

        <label class="f2d2-clothing-quote-modal__wide">
          <span>Details du projet *</span>
          <textarea name="contact[body]" rows="6" required placeholder="Dimensions, couleurs, fichiers/logo disponibles, type de materiel, finition, contraintes, delai..."></textarea>
        </label>
      </div>

      <p class="f2d2-clothing-quote-modal__hint">
        Pour joindre un logo ou un fichier, mentionnez-le dans le message. Nous vous repondrons avec la meilleure facon de l'envoyer.
      </p>

      <button type="submit" class="f2d2-clothing-quote-modal__submit">Envoyer la demande</button>
    {% endform %}
  </div>
</div>

<style>
  html.f2d2-clothing-quote-open {
    overflow: hidden;
  }

  .f2d2-clothing-quote-modal[hidden] {
    display: none;
  }

  .f2d2-clothing-quote-modal {
    position: fixed;
    inset: 0;
    z-index: 1000000;
    display: grid;
    place-items: center;
    padding: clamp(1.2rem, 2vw, 2.4rem);
    color: #ffffff;
    background: rgba(6, 10, 16, 0.76);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .f2d2-clothing-quote-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.18);
  }

  .f2d2-clothing-quote-modal__panel {
    scrollbar-color: rgba(0, 132, 255, 0.9) rgba(6, 10, 16, 0.72);
    scrollbar-width: thin;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    width: min(100%, 104rem);
    max-height: calc(100dvh - 4.8rem);
    overflow: auto;
    padding: 3.2rem 3.2rem 2.8rem;
    color: #ffffff;
    background: #0f141b;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 2rem;
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.45);
    outline: none;
    isolation: isolate;
  }

  .f2d2-clothing-quote-modal__panel::-webkit-scrollbar {
    width: 10px;
  }

  .f2d2-clothing-quote-modal__panel::-webkit-scrollbar-track {
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(4, 9, 15, 0.96), rgba(12, 18, 28, 0.96));
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .f2d2-clothing-quote-modal__panel::-webkit-scrollbar-thumb {
    border: 2px solid rgba(6, 10, 16, 0.98);
    border-radius: 999px;
    background: linear-gradient(180deg, #5ea7ff 0%, #0084ff 45%, #0048b8 100%);
    box-shadow: 0 0 14px rgba(0, 132, 255, 0.42);
  }

  .f2d2-clothing-quote-modal__close {
    position: absolute;
    top: 1.2rem;
    right: 1.2rem;
    width: 3.8rem;
    height: 3.8rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #ffffff;
    background: rgba(255, 255, 255, 0.06);
    font-size: 3rem;
    line-height: 1;
    cursor: pointer;
  }

  .f2d2-clothing-quote-modal__head {
    max-width: 72rem;
    margin-bottom: 2.2rem;
    padding-right: 6rem;
  }

  .f2d2-clothing-quote-modal__eyebrow {
    margin: 0 0 1rem;
    color: #5ea7ff;
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .f2d2-clothing-quote-modal__head h2 {
    margin: 0;
    font-size: clamp(4.2rem, 4.8vw, 5.8rem);
    line-height: 0.96;
  }

  .f2d2-clothing-quote-modal__head p {
    margin: 0.9rem 0 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 1.6rem;
  }

  .f2d2-clothing-quote-modal__form {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    width: 100%;
  }

  .f2d2-clothing-quote-modal__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.6rem;
    width: 100%;
  }

  .f2d2-clothing-quote-modal label {
    display: grid;
    gap: 0.4rem;
    margin: 0;
    min-width: 0;
  }

  .f2d2-clothing-quote-modal label span {
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .f2d2-clothing-quote-modal input,
  .f2d2-clothing-quote-modal select,
  .f2d2-clothing-quote-modal textarea {
    width: 100%;
    min-height: 5rem;
    padding: 1.2rem 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 1rem;
    color: #ffffff;
    background: #151b23 !important;
    box-shadow: none;
    font-size: 1.6rem;
    line-height: 1.35;
  }

  .f2d2-clothing-quote-modal select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
  }

  .f2d2-clothing-quote-modal select option {
    color: #ffffff;
    background: #0f141b;
  }

  .f2d2-clothing-quote-modal textarea {
    min-height: 13rem;
    resize: vertical;
  }

  .f2d2-clothing-quote-modal input::placeholder,
  .f2d2-clothing-quote-modal textarea::placeholder {
    color: rgba(255, 255, 255, 0.52);
  }

  .f2d2-clothing-quote-modal__wide,
  .f2d2-clothing-quote-modal__status,
  .f2d2-clothing-quote-modal__hint {
    grid-column: 1 / -1;
  }

  .f2d2-clothing-quote-modal__hint {
    margin: 0;
    color: rgba(255, 255, 255, 0.60);
    font-size: 1.2rem;
    line-height: 1.45;
  }

  .f2d2-clothing-quote-modal__status {
    margin-bottom: 1.2rem;
    padding: 1.2rem 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    font-weight: 800;
  }

  .f2d2-clothing-quote-modal__status--success {
    background: rgba(31, 143, 78, 0.22);
  }

  .f2d2-clothing-quote-modal__status--error {
    background: rgba(185, 45, 45, 0.22);
  }

  .f2d2-clothing-quote-modal__submit {
    width: 100%;
    min-height: 5.4rem;
    padding: 1.4rem 2rem;
    border: 1px solid #5ea7ff;
    border-radius: 1rem;
    color: #ffffff;
    background: linear-gradient(180deg, #1b7dff 0%, #0048b8 100%);
    box-shadow:
      0 16px 34px rgba(0, 72, 184, 0.35),
      inset 0 0 0 1px rgba(255, 255, 255, 0.22);
    font-weight: 900;
    text-transform: uppercase;
    cursor: pointer;
  }

  @media (max-width: 749px) {
    .f2d2-clothing-quote-modal {
      align-items: start;
      padding: max(1rem, env(safe-area-inset-top)) 1rem max(1rem, env(safe-area-inset-bottom));
      overflow-y: auto;
    }

    .f2d2-clothing-quote-modal__panel {
      width: 100%;
      max-height: calc(100dvh - 2rem);
      padding: 2rem 1.6rem calc(2.4rem + env(safe-area-inset-bottom));
      border-radius: 1.4rem;
      overscroll-behavior: contain;
    }

    .f2d2-clothing-quote-modal__head {
      padding-right: 4.8rem;
      margin-bottom: 1rem;
    }

    .f2d2-clothing-quote-modal__head h2 {
      font-size: clamp(3rem, 9vw, 4.2rem);
    }

    .f2d2-clothing-quote-modal__grid {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
  }
</style>

<script>
  (() => {
    const modal = document.getElementById({{ modal_id | json }});
    if (!modal) return;

    const panel = modal.querySelector('.f2d2-clothing-quote-modal__panel');
    const closeButtons = modal.querySelectorAll('[data-f2d2-clothing-quote-close]');
    const hasStatus = modal.querySelector('.f2d2-clothing-quote-modal__status');
    let previousFocus = null;

    const openModal = () => {
      previousFocus = document.activeElement;
      modal.hidden = false;
      document.documentElement.classList.add('f2d2-clothing-quote-open');
      panel.focus();
    };

    const closeModal = () => {
      modal.hidden = true;
      document.documentElement.classList.remove('f2d2-clothing-quote-open');
      if (previousFocus && previousFocus.focus) previousFocus.focus();
    };

    document.addEventListener('click', (event) => {
      const trigger = event.target.closest('[data-f2d2-clothing-quote-open]');
      if (!trigger) return;
      event.preventDefault();
      openModal();
    });

    closeButtons.forEach((button) => button.addEventListener('click', closeModal));

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !modal.hidden) closeModal();
    });

    if (hasStatus) openModal();
  })();
</script>

{% schema %}
{
  "name": "F2D2 Clothing Quote Modal",
  "tag": "section",
  "class": "section-f2d2-clothing-quote-modal",
  "settings": [],
  "presets": [
    {
      "name": "F2D2 Clothing Quote Modal"
    }
  ]
}
{% endschema %}

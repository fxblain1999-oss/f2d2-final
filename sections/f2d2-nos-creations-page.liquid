    }

    .section-{{ section.id }} .f2d2-creation-card__content {
      max-width: 92%;
    }
  }
</style>

<script>
  (() => {
    const root = document.querySelector('[data-f2d2-creations]');
    if (!root) return;

    const tabs = Array.from(root.querySelectorAll('[data-filter]'));
    const select = root.querySelector('[data-f2d2-creations-select]');
    const groups = Array.from(root.querySelectorAll('[data-category]'));

    const applyFilter = (value) => {
      tabs.forEach((tab) => tab.classList.toggle('is-active', tab.dataset.filter === value));
      if (select && select.value !== value) select.value = value;
      groups.forEach((group) => {
        group.classList.toggle('is-hidden', value !== 'all' && group.dataset.category !== value);
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => applyFilter(tab.dataset.filter));
    });

    if (select) {
      select.addEventListener('change', (event) => applyFilter(event.target.value));
    }

  })();
</script>

{%- endif -%}


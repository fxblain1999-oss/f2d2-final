{{ 'f2d2-creations-hero-bg.png' | asset_url | preload_tag: as: 'image' }}

{%- if page.handle == 'nos-creations' -%}

{%- liquid
  assign contact_url = '/pages/contact'
  assign web_url = '/pages/creation-de-sites-webs'
  assign services_url = '/pages/nos-services'
-%}

<section class="f2d2-creations-page section-{{ section.id }}" data-f2d2-creations>
  <div class="f2d2-creations-hero">
    <div class="f2d2-creations__wrap f2d2-creations-hero__inner">
      <div class="f2d2-creations-hero__copy">
        <p class="f2d2-creations__eyebrow">Nos creations</p>
        <h1>
          Des sites web<br>
          pensés pour convertir<br>
          <span>vos visiteurs en clients</span>
        </h1>
        <p>
          Des expériences web modernes pensées pour valoriser votre marque et offrir une présence en ligne à la hauteur de votre entreprise.
        </p>
        <div class="f2d2-creations-actions">
          <a href="{{ web_url }}" class="f2d2-creations-btn f2d2-creations-btn--ghost">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7-11-7Z"/></svg>
            Découvrir nos projets
          </a>
          <a href="#f2d2-web-quote-modal" class="f2d2-creations-btn f2d2-creations-btn--primary" data-f2d2-web-quote-open>
            Discutons de votre projet
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="f2d2-creations__wrap f2d2-creations-content">
    <div class="f2d2-creations-tabs" aria-label="Categories de projets">
      <button type="button" class="is-active" data-filter="all">Tous</button>
      <button type="button" data-filter="landing">Landing page</button>
      <button type="button" data-filter="shop">Boutique en ligne</button>
      <button type="button" data-filter="blog">Blog</button>
      <button type="button" data-filter="corporate">Site corporatif</button>
    </div>

    <label class="f2d2-creations-select">
      <span class="visually-hidden">Choisir une categorie</span>
      <select data-f2d2-creations-select>
        <option value="all">Tous</option>
        <option value="landing">Landing page</option>
        <option value="shop">Boutique en ligne</option>
        <option value="blog">Blog</option>
        <option value="corporate">Site corporatif</option>
      </select>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
    </label>

    <div class="f2d2-creations-groups">
      <section class="f2d2-creations-group" data-category="landing">
        <div class="f2d2-creations-group__head">
          <h2>Landing page</h2>
          <a href="{{ contact_url }}">Voir tous <span aria-hidden="true">-></span></a>
        </div>
        <div class="f2d2-creations-row" data-f2d2-creations-row>
          <article class="f2d2-creation-card f2d2-creation-card--mountain">
            <a href="{{ contact_url }}" aria-label="Projet Aventure sans limites">
              <span class="f2d2-creation-card__content">
                <strong>Aventure<br>sans limites</strong>
                <small>Landing page</small>
              </span>
            </a>
          </article>
          <article class="f2d2-creation-card f2d2-creation-card--fitness">
            <a href="{{ contact_url }}" aria-label="Projet entraine ton corps et ton mental">
              <span class="f2d2-creation-card__content">
                <strong>Entraine ton<br>corps et ton mental</strong>
                <small>Landing page</small>
              </span>
            </a>
          </article>
          <article class="f2d2-creation-card f2d2-creation-card--studio">
            <a href="{{ contact_url }}" aria-label="Projet experiences digitales">
              <span class="f2d2-creation-card__content">
                <strong>Experiences digitales<br>qui connectent</strong>
                <small>Landing page</small>
              </span>
            </a>
          </article>
          <article class="f2d2-creation-card f2d2-creation-card--launch">
            <a href="{{ contact_url }}" aria-label="Projet lance ta marque">
              <span class="f2d2-creation-card__content">
                <strong>Lance ta<br>marque</strong>
                <small>Landing page</small>
              </span>
            </a>
          </article>
        </div>
      </section>

      <section class="f2d2-creations-group" data-category="shop">
        <div class="f2d2-creations-group__head">
          <h2>Boutique en ligne</h2>
          <a href="{{ services_url }}">Voir tous <span aria-hidden="true">-></span></a>
        </div>
        <div class="f2d2-creations-row" data-f2d2-creations-row>
          <article class="f2d2-creation-card f2d2-creation-card--beauty">
            <a href="{{ contact_url }}" aria-label="Projet beaute naturelle">
              <span class="f2d2-creation-card__content">
                <strong>Beaute naturelle<br>pour ta peau</strong>
                <small>Boutique en ligne</small>
              </span>
            </a>
          </article>
          <article class="f2d2-creation-card f2d2-creation-card--audio">
            <a href="{{ contact_url }}" aria-label="Projet audio">
              <span class="f2d2-creation-card__content">
                <strong>Son qui<br>t'enveloppe</strong>
                <small>Boutique en ligne</small>
              </span>
            </a>
          </article>
          <article class="f2d2-creation-card f2d2-creation-card--home">
            <a href="{{ contact_url }}" aria-label="Projet maison">
              <span class="f2d2-creation-card__content">
                <strong>Design qui transforme<br>ta maison</strong>
                <small>Boutique en ligne</small>
              </span>
            </a>
          </article>
          <article class="f2d2-creation-card f2d2-creation-card--green">
            <a href="{{ contact_url }}" aria-label="Projet green shop">
              <span class="f2d2-creation-card__content">
                <strong>Maison Éco Living</strong>
                <small>Boutique en ligne</small>
              </span>
            </a>
          </article>
        </div>
      </section>

      <section class="f2d2-creations-group" data-category="blog">
        <div class="f2d2-creations-group__head">
          <h2>Blog</h2>
          <a href="{{ web_url }}">Voir tous <span aria-hidden="true">-></span></a>
        </div>
        <div class="f2d2-creations-row" data-f2d2-creations-row>
          <article class="f2d2-creation-card f2d2-creation-card--travel">
            <a href="{{ contact_url }}" aria-label="Projet blog de voyages">
              <span class="f2d2-creation-card__content">
                <strong>Mon blog de voyages</strong>
                <small>Blog</small>
              </span>
            </a>
          </article>
          <article class="f2d2-creation-card f2d2-creation-card--stories">
            <a href="{{ contact_url }}" aria-label="Projet histoires qui inspirent">
              <span class="f2d2-creation-card__content">
                <strong>Histoires qui<br>inspirent</strong>
                <small>Blog</small>
              </span>
            </a>
          </article>
          <article class="f2d2-creation-card f2d2-creation-card--learning">
            <a href="{{ contact_url }}" aria-label="Projet apprendre ensemble">
              <span class="f2d2-creation-card__content">
                <strong>Apprendre<br>ensemble</strong>
                <small>Blog</small>
              </span>
            </a>
          </article>
          <article class="f2d2-creation-card f2d2-creation-card--city">
            <a href="{{ contact_url }}" aria-label="Projet notes de developpement">
              <span class="f2d2-creation-card__content">
                <strong>Notes de<br>developpement</strong>
                <small>Blog</small>
              </span>
            </a>
          </article>
        </div>
      </section>

      <section class="f2d2-creations-group" data-category="corporate">
        <div class="f2d2-creations-group__head">
          <h2>Site corporatif</h2>
          <a href="{{ services_url }}">Voir tous <span aria-hidden="true">-></span></a>
        </div>
        <div class="f2d2-creations-row" data-f2d2-creations-row>
          <article class="f2d2-creation-card f2d2-creation-card--agency">
            <a href="{{ contact_url }}" aria-label="Projet studio corporatif">
              <span class="f2d2-creation-card__content">
                <strong>Presence claire<br>et credible</strong>
                <small>Site corporatif</small>
              </span>
            </a>
          </article>
          <article class="f2d2-creation-card f2d2-creation-card--service">
            <a href="{{ contact_url }}" aria-label="Projet services experts">
              <span class="f2d2-creation-card__content">
                <strong>Cabinet Nova<br>bien presentes</strong>
                <small>Site corporatif</small>
              </span>
            </a>
          </article>
          <article class="f2d2-creation-card f2d2-creation-card--portfolio">
            <a href="{{ contact_url }}" aria-label="Projet portfolio pro">
              <span class="f2d2-creation-card__content">
                <strong>Studio<br>Horizon</strong>
                <small>Site corporatif</small>
              </span>
            </a>
          </article>
          <article class="f2d2-creation-card f2d2-creation-card--consulting">
            <a href="{{ contact_url }}" aria-label="Projet conseil">
              <span class="f2d2-creation-card__content">
                <strong>Confiance<br>des le premier clic</strong>
                <small>Site corporatif</small>
              </span>
            </a>
          </article>
        </div>
      </section>
    </div>

    <section class="f2d2-creations-cta">
      <div class="f2d2-creations-cta__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>
      </div>
      <div>
        <h2>Parlons de votre prochain projet web</h2>
        <p>Créons ensemble une expérience moderne, rapide et pensée pour vos objectifs.</p>
      </div>
      <a href="#f2d2-web-quote-modal" class="f2d2-creations-btn f2d2-creations-btn--primary" data-f2d2-web-quote-open>
        Contactez-moi
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
      </a>
    </section>
  </div>

  {% render 'f2d2-web-quote-modal', root_selector: '.f2d2-creations-page' %}

</section>

<style>
  body:has(.f2d2-creations-page) .main-page-title,
  body:has(.f2d2-creations-page) .page__content:empty,
  body:has(.f2d2-creations-page) .announcement-bar-section {
    display: none;
  }

  body:has(.f2d2-creations-page) .section--padding {
    padding-top: 0;
    padding-bottom: 0;
  }


  .section-{{ section.id }} {
    --creations-bg: #020407;
    --creations-panel: rgba(9, 14, 21, 0.82);
    --creations-panel-strong: rgba(11, 17, 27, 0.96);
    --creations-line: rgba(255, 255, 255, 0.13);
    --creations-line-strong: rgba(255, 255, 255, 0.23);
    --creations-blue: #0A84FF;
    --creations-blue-strong: #0054c8;
    --creations-muted: rgba(255, 255, 255, 0.68);
    background: var(--creations-bg);
    color: #fff;
    overflow: hidden;
  }

  .section-{{ section.id }} *,
  .section-{{ section.id }} *::before,
  .section-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .section-{{ section.id }} svg {
    display: block;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .section-{{ section.id }} .f2d2-creations__wrap {
    width: min(1440px, calc(100% - 64px));
    margin: 0 auto;
  }

  .section-{{ section.id }} .f2d2-creations-hero {
    position: relative;
    min-height: clamp(620px, 48vw, 780px);
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(90deg, #020407 0%, rgba(2, 4, 7, 0.96) 25%, rgba(2, 4, 7, 0.68) 43%, rgba(2, 4, 7, 0.12) 72%, rgba(2, 4, 7, 0.52) 100%),
      linear-gradient(180deg, rgba(2, 4, 7, 0.04) 0%, rgba(2, 4, 7, 0) 58%, #020407 100%),
      url({{ 'f2d2-creations-hero-bg.png' | asset_url }}) center right / cover no-repeat;
  }

  .section-{{ section.id }} .f2d2-creations-hero__inner {
    position: relative;
    z-index: 2;
    padding: 88px 0 74px;
  }

  .section-{{ section.id }} .f2d2-creations-hero__copy {
    max-width: 640px;
  }

  .section-{{ section.id }} .f2d2-creations__eyebrow {
    margin: 0 0 18px;
    color: var(--creations-blue);
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .section-{{ section.id }} .f2d2-creations-hero h1 {
    font-size: clamp(38px, 4.2vw, 66px);
    line-height: 0.95;
    letter-spacing: -2px;
    max-width: 700px;
  }

  .section-{{ section.id }} .f2d2-creations-hero h1 span {
    display: block;
    color: var(--creations-blue);
  }

  .section-{{ section.id }} .f2d2-creations-hero p:not(.f2d2-creations__eyebrow) {
    max-width: 520px;
    margin: 22px 0 0;
    color: var(--creations-muted);
    font-size: 16px;
    line-height: 1.65;
  }

  .section-{{ section.id }} .f2d2-creations-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }

  .section-{{ section.id }} .f2d2-creations-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    min-height: 48px;
    padding: 0 24px;
    border: 1px solid var(--creations-line-strong);
    border-radius: 4px;
    color: #fff;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .section-{{ section.id }} .f2d2-creations-btn svg {
    width: 18px;
    height: 18px;
  }

  .section-{{ section.id }} .f2d2-creations-btn:hover {
    transform: translateY(-2px);
    border-color: rgba(5, 120, 255, 0.78);
  }

  .section-{{ section.id }} .f2d2-creations-btn--primary {
    border-color: rgba(5, 120, 255, 0.92);
    background: linear-gradient(135deg, var(--creations-blue-strong), var(--creations-blue));
    box-shadow: 0 16px 36px rgba(0, 83, 200, 0.28);
  }

  .section-{{ section.id }} .f2d2-creations-content {
    padding: 28px 0 54px;
  }

  .section-{{ section.id }} .f2d2-creations-tabs {
    display: flex;
    justify-content: center;
    gap: clamp(18px, 4vw, 58px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: 34px;
  }

  .section-{{ section.id }} .f2d2-creations-tabs button {
    position: relative;
    appearance: none;
    border: 0;
    background: transparent;
    color: rgba(255, 255, 255, 0.78);
    padding: 0 0 18px;
    font: inherit;
    font-size: 14px;
    cursor: pointer;
  }

  .section-{{ section.id }} .f2d2-creations-tabs button::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 2px;
    background: transparent;
  }

  .section-{{ section.id }} .f2d2-creations-tabs button.is-active {
    color: var(--creations-blue);
  }

  .section-{{ section.id }} .f2d2-creations-tabs button.is-active::after {
    background: var(--creations-blue);
  }

  .section-{{ section.id }} .f2d2-creations-select {
    position: relative;
    display: none;
    margin: 0 0 26px;
  }

  .section-{{ section.id }} .f2d2-creations-select select {
    width: 100%;
    height: 48px;
    appearance: none;
    border: 1px solid var(--creations-line-strong);
    border-radius: 4px;
    background: rgba(4, 8, 14, 0.9);
    color: #fff;
    padding: 0 46px 0 16px;
    font: inherit;
    font-size: 14px;
  }

  .section-{{ section.id }} .f2d2-creations-select svg {
    position: absolute;
    right: 16px;
    top: 50%;
    width: 18px;
    height: 18px;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .section-{{ section.id }} .f2d2-creations-groups {
    display: grid;
    gap: 32px;
  }

  .section-{{ section.id }} .f2d2-creations-group.is-hidden {
    display: none;
  }

  .section-{{ section.id }} .f2d2-creations-group__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 14px;
  }

  .section-{{ section.id }} .f2d2-creations-group__head h2,
  .section-{{ section.id }} .f2d2-creations-cta h2 {
    margin: 0;
    color: #fff;
    font-size: clamp(20px, 2vw, 28px);
    line-height: 1.12;
    font-weight: 850;
    letter-spacing: 0;
  }

  .section-{{ section.id }} .f2d2-creations-group__head a {
    color: var(--creations-blue);
    font-size: 13px;
    font-weight: 750;
    text-decoration: none;
    white-space: nowrap;
  }

  .section-{{ section.id }} .f2d2-creations-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .section-{{ section.id }} .f2d2-creation-card {
    min-height: 162px;
    border: 1px solid var(--creations-line);
    border-radius: 6px;
    overflow: hidden;
    background: #0c1118;
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .section-{{ section.id }} .f2d2-creation-card:hover {
    transform: translateY(-4px) scale(1.02);
    border-color: rgba(5, 120, 255, 0.52);
  }

  .section-{{ section.id }} .f2d2-creation-card a {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: 162px;
    height: 100%;
    padding: 24px 22px;
    color: #fff;
    text-decoration: none;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.78), rgba(0, 0, 0, 0.14) 70%),
      var(--card-bg, linear-gradient(135deg, #1b2632, #090d13));
    background-size: cover;
    background-position: center;
  }

  .section-{{ section.id }} .f2d2-creation-card a::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.38) 100%);
    pointer-events: none;
  }

  .section-{{ section.id }} .f2d2-creation-card__content {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 18px;
    max-width: 82%;
  }

  .section-{{ section.id }} .f2d2-creation-card strong {
    color: #fff;
    font-size: clamp(17px, 1.45vw, 24px);
    line-height: 1.05;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .section-{{ section.id }} .f2d2-creation-card small {
    width: fit-content;
    color: rgba(255, 255, 255, 0.82);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    padding: 7px 10px;
    font-size: 11px;
    line-height: 1;
  }

  .section-{{ section.id }} .f2d2-creation-card--mountain,
  .section-{{ section.id }} .f2d2-creation-card--travel {
    --card-bg: url({{ 'f2d2-realizations-hero-wide.png' | asset_url }});
  }

  .section-{{ section.id }} .f2d2-creation-card--fitness {
    --card-bg:
      radial-gradient(circle at 68% 42%, rgba(255, 255, 255, 0.2), transparent 9rem),
      linear-gradient(115deg, #090b0f 0%, #111923 42%, #050608 100%);
  }

  .section-{{ section.id }} .f2d2-creation-card--studio,
  .section-{{ section.id }} .f2d2-creation-card--launch,
  .section-{{ section.id }} .f2d2-creation-card--agency,
  .section-{{ section.id }} .f2d2-creation-card--portfolio {
    --card-bg: url({{ 'f2d2-web-hero-crop.png' | asset_url }});
  }

  .section-{{ section.id }} .f2d2-creation-card--beauty {
    --card-bg:
      linear-gradient(90deg, rgba(235, 224, 217, 0.96), rgba(235, 224, 217, 0.38)),
      url({{ 'card-1.png' | asset_url }});
  }

  .section-{{ section.id }} .f2d2-creation-card--beauty strong,
  .section-{{ section.id }} .f2d2-creation-card--green strong {
    color: #151515;
    text-transform: none;
  }

  .section-{{ section.id }} .f2d2-creation-card--beauty small,
  .section-{{ section.id }} .f2d2-creation-card--green small {
    color: #fff;
    background: rgba(0, 0, 0, 0.52);
  }

  .section-{{ section.id }} .f2d2-creation-card--audio {
    --card-bg:
      radial-gradient(circle at 70% 50%, rgba(255, 255, 255, 0.2), transparent 8rem),
      linear-gradient(120deg, #030507 0%, #151923 56%, #020305 100%);
  }

  .section-{{ section.id }} .f2d2-creation-card--home {
    --card-bg: url({{ 'card-bg-group-b.png' | asset_url }});
  }

  .section-{{ section.id }} .f2d2-creation-card--green {
    --card-bg:
      linear-gradient(90deg, rgba(238, 240, 235, 0.92), rgba(238, 240, 235, 0.45)),
      url({{ 'card-bg-group-a.png' | asset_url }});
  }

  .section-{{ section.id }} .f2d2-creation-card--stories {
    --card-bg:
      linear-gradient(120deg, rgba(37, 21, 10, 0.94), rgba(8, 6, 5, 0.55)),
      url({{ 'corporate_bg.png' | asset_url }});
  }

  .section-{{ section.id }} .f2d2-creation-card--learning,
  .section-{{ section.id }} .f2d2-creation-card--service,
  .section-{{ section.id }} .f2d2-creation-card--consulting {
    --card-bg:
      linear-gradient(120deg, rgba(12, 16, 20, 0.86), rgba(45, 49, 53, 0.42)),
      url({{ 'hero-bg.png' | asset_url }});
  }

  .section-{{ section.id }} .f2d2-creation-card--city {
    --card-bg:
      linear-gradient(120deg, rgba(2, 5, 9, 0.88), rgba(55, 62, 70, 0.38)),
      url({{ 'section_bg.png' | asset_url }});
  }

  .section-{{ section.id }} .f2d2-creations-cta {
    display: grid;

    .section-{{ section.id }} .f2d2-creations-hero__inner {
      padding-top: 50px;
      padding-bottom: 190px;
    }

    .section-{{ section.id }} .f2d2-creations-hero {
      min-height: 650px;
      background:
        linear-gradient(180deg, rgba(2, 4, 7, 0.24) 0%, rgba(2, 4, 7, 0.86) 48%, #020407 91%),

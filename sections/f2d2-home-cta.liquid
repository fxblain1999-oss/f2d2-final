{% assign section_id = 'f2d2-home-cta-' | append: section.id %}

<section id="{{ section_id }}" class="f2d2-home-cta">
  <div class="page-width">
    <div class="f2d2-home-cta__box">
      {% if section.settings.heading != blank %}
        <h2 class="f2d2-home-cta__title">{{ section.settings.heading }}</h2>
      {% endif %}

      <div class="f2d2-home-cta__actions">
        {% if section.settings.primary_label != blank %}
          <a href="https://f2d2.ca/pages/contact" class="f2d2-home-cta__btn f2d2-home-cta__btn--primary">{{ section.settings.primary_label }}</a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a href="https://f2d2.ca/collections/all" class="f2d2-home-cta__btn f2d2-home-cta__btn--secondary">{{ section.settings.secondary_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    margin: 0 !important;
    padding: 0 !important;
    font-size: 0 !important;
    line-height: 0 !important;
  }

  #{{ section_id }} {
    padding: 1.8rem 0 2.2rem;
    font-size: var(--font-body-size);
    line-height: var(--font-body-line-height);
    background:
      linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)),
      url({{ 'section_bg.png' | asset_url }});
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    color: #fff;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  #{{ section_id }} .f2d2-home-cta__box {
    padding: 0;
    text-align: center;
  }

  #{{ section_id }} .f2d2-home-cta__title {
    margin: 0;
    font-size: clamp(2.3rem, 4.5vw, 3.9rem);
    line-height: 0.94;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  #{{ section_id }} .f2d2-home-cta__actions {
    margin-top: 1.45rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: center;
  }

  #{{ section_id }} .f2d2-home-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.3rem;
    width: min(100%, 25rem);
    padding: 0.9rem 2rem;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 800;
    border: 1px solid rgba(255, 255, 255, 0.28);
  }

  #{{ section_id }} .f2d2-home-cta__btn--primary {
    background: linear-gradient(180deg, #1b7dff 0%, #0048b8 100%);
    border-color: #5ea7ff;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  #{{ section_id }} .f2d2-home-cta__btn--secondary {
    background: linear-gradient(180deg, #ffffff 0%, #d6d6d6 100%);
    border-color: rgba(255, 255, 255, 0.55);
    color: #111;
  }

  @media screen and (min-width: 990px) {
    #{{ section_id }} {
      padding: 2.1rem 0 2.45rem;
    }

    #{{ section_id }} .f2d2-home-cta__actions {
      flex-direction: row;
      justify-content: center;
      gap: 1.25rem;
    }

    #{{ section_id }} .f2d2-home-cta__btn {
      width: 25rem;
    }
  }
</style>

{% schema %}
{
  "name": "F2D2 Home CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Pret a lancer votre projet ?"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Bouton principal",
      "default": "Soumission rapide"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Lien principal"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Bouton secondaire",
      "default": "Commander"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Lien secondaire"
    }
  ],
  "presets": [
    {
      "name": "F2D2 Home CTA"
    }
  ]
}
{% endschema %}

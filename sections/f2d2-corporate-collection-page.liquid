{%- if collection.handle == 'corporatif' -%}
  {%- liquid
    assign quote_target = '#f2d2-clothing-quote-modal'
    assign realizations_url = routes.collections_url | append: '/design-f2d2'
    assign clothing_url = '/pages/vetements'
    assign collections_url = routes.collections_url
  -%}

  <section class="f2d2-corporate-page section-{{ section.id }}">
    <div class="f2d2-corporate-hero">
      <div class="f2d2-corporate-hero__media" aria-hidden="true">
        <img
          src="{{ 'corporate_bg.png' | asset_url }}"
          alt=""
          width="1920"
          height="800"
          loading="eager"
          class="f2d2-corporate-hero__image"
        >
      </div>

      <div class="f2d2-corporate__wrap f2d2-corporate-hero__inner">
        <div class="f2d2-corporate-hero__copy">
          <p class="f2d2-corporate__eyebrow">Collection corporative</p>
          <h1>Votre image de marque sur tous vos produits.</h1>
          <p>
            Vêtements personnalisés, cadeaux corporatifs, affichage, signalisation,
            UV DTF et articles promotionnels.
          </p>

          <div class="f2d2-corporate__actions">
            <a href="{{ quote_target }}" class="f2d2-corporate-btn f2d2-corporate-btn--primary" data-f2d2-clothing-quote-open>
              Demander une soumission
            </a>
            <a href="{{ realizations_url }}" class="f2d2-corporate-btn f2d2-corporate-btn--ghost">
              Voir nos réalisations
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="f2d2-corporate__wrap f2d2-corporate-body">
      <section class="f2d2-corporate-intro">
        <div class="f2d2-corporate-benefits-block">
          <div class="f2d2-corporate-section__head">
            <h2>Pourquoi choisir F2D2 ?</h2>
          </div>

          <div class="f2d2-corporate-benefits">
            <article>
              <span aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M5 19c7-1 12-6 14-14-8 2-13 7-14 14Z"/><path d="M5 19 3 21"/><path d="m12 12 4 4"/><path d="M8 16l-1-5 5 1"/></svg>
              </span>
              <h3>Production rapide</h3>
              <p>Délais respectés et livraison partout au Canada.</p>
            </article>

            <article>
              <span aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="m14 4 6 6L9 21H3v-6L14 4Z"/><path d="m13 5 6 6"/><path d="m4 20 5-1"/></svg>
              </span>
              <h3>Design graphique inclus</h3>
              <p>Maquettes claires et prêtes à approuver.</p>
            </article>

            <article>
              <span aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 3c2 4 5 6 9 7-4 1-7 3-9 7-2-4-5-6-9-7 4-1 7-3 9-7Z"/><path d="M12 17v4"/><path d="M8 21h8"/></svg>
              </span>
              <h3>Entreprise locale</h3>
              <p>Service humain, flexible et proche de vos besoins.</p>
            </article>

            <article>
              <span aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M20 13 13 20 4 11V4h7l9 9Z"/><path d="M8 8h.01"/><path d="M12 9v6"/><path d="M15 10.5h-4.5a1.5 1.5 0 0 0 0 3H13a1.5 1.5 0 0 1 0 3H8"/></svg>
              </span>
              <h3>Prix de volume compétitifs</h3>
              <p>Tarifs adaptés aux petites et grandes quantités.</p>
            </article>
          </div>
        </div>

        <div class="f2d2-corporate-process">
          <h2>Comment ça fonctionne ?</h2>
          <ol>
            <li><strong>Soumission</strong><span>Vous nous envoyez votre projet.</span></li>
            <li><strong>Approbation</strong><span>Nous validons une maquette claire.</span></li>
            <li><strong>Production</strong><span>On produit vos articles avec soin.</span></li>
            <li><strong>Livraison</strong><span>Livraison rapide à votre entreprise.</span></li>
          </ol>
        </div>

        <div class="f2d2-corporate-volume">
          <img src="{{ 'f2d2-hero-merch.png' | asset_url }}" alt="" width="900" height="520" loading="lazy">
          <div>
            <h2>Commandes corporatives</h2>
            <p>Besoin de 25, 50, 100 ou 1000 unités ? Nous offrons des tarifs adaptés aux entreprises, organismes et municipalités.</p>
            <a href="{{ quote_target }}" data-f2d2-clothing-quote-open>Obtenir un prix</a>
          </div>
        </div>
      </section>

      <section class="f2d2-corporate-section f2d2-corporate-section--categories">
        <div class="f2d2-corporate-section__head">
          <h2>Tout ce qu'il vous faut pour votre entreprise</h2>
        </div>

        <div class="f2d2-corporate-categories">
          <article>
            <a href="{{ clothing_url }}">
              <img src="{{ 'f2d2-project-team-collection.png' | asset_url }}" alt="" width="900" height="560" loading="lazy">
              <div>
                <h3>Vêtements</h3>
                <p>Chandails<br>Hoodies<br>Vestes<br>Casquettes</p>
                <span>Voir tous les vêtements →</span>
              </div>
            </a>
          </article>

          <article>
            <a href="{{ collections_url }}">
              <img src="{{ 'f2d2-hero-merch.png' | asset_url }}" alt="" width="900" height="560" loading="lazy">
              <div>
                <h3>Accessoires</h3>
                <p>Tasses<br>Bouteilles<br>Sacs<br>Stylos</p>
                <span>Voir tous les accessoires →</span>
              </div>
            </a>
          </article>

          <article>
            <a href="{{ collections_url }}">
              <img src="{{ 'f2d2-project-smokehouse-bbq.png' | asset_url }}" alt="" width="900" height="560" loading="lazy">
              <div>
                <h3>Affichage</h3>
                <p>Bannières<br>Coroplastes<br>Enseignes<br>Autocollants muraux</p>
                <span>Voir tout l'affichage →</span>
              </div>
            </a>
          </article>

          <article>
            <a href="{{ collections_url }}">
              <img src="{{ 'f2d2-realizations-hero-wide.png' | asset_url }}" alt="" width="900" height="560" loading="lazy">
              <div>
                <h3>Promotion</h3>
                <p>UV DTF<br>Stickers<br>Cadeaux clients<br>Articles promotionnels</p>
                <span>Voir tous les produits promo →</span>
              </div>
            </a>
          </article>
        </div>
      </section>

      <section class="f2d2-corporate-section f2d2-corporate-section--realizations">
        <div class="f2d2-corporate-section__head f2d2-corporate-section__head--split">
          <h2>Nos réalisations</h2>
          <a href="{{ realizations_url }}">Voir plus de réalisations →</a>
        </div>

        <div class="f2d2-corporate-gallery">
          <a href="{{ realizations_url }}" class="f2d2-corporate-gallery__large"><img src="{{ 'f2d2-project-team-collection.png' | asset_url }}" alt="" width="1100" height="760" loading="lazy"></a>
          <a href="{{ realizations_url }}"><img src="{{ 'f2d2-project-smokehouse-bbq.png' | asset_url }}" alt="" width="900" height="560" loading="lazy"></a>
          <a href="{{ realizations_url }}"><img src="{{ 'f2d2-realizations-hero-wide.png' | asset_url }}" alt="" width="900" height="560" loading="lazy"></a>
          <a href="{{ realizations_url }}"><img src="{{ 'f2d2-hero-merch.png' | asset_url }}" alt="" width="900" height="560" loading="lazy"></a>
          <a href="{{ realizations_url }}"><img src="{{ 'corporate_bg.png' | asset_url }}" alt="" width="900" height="560" loading="lazy"></a>
          <a href="{{ realizations_url }}"><img src="{{ 'f2d2-web-hero-crop.png' | asset_url }}" alt="" width="900" height="560" loading="lazy"></a>
        </div>
      </section>

      <section class="f2d2-corporate-section f2d2-corporate-reviews">
        <div class="f2d2-corporate-section__head">
          <h2>Ils nous ont fait confiance</h2>
        </div>

        <div class="f2d2-corporate-reviews__grid">
          <blockquote>
            <strong>★★★★★</strong>
            <p>Service impeccable et produits de qualité. Nos chandails corporatifs sont parfaits.</p>
            <cite>Julien R.<span>Construction</span></cite>
          </blockquote>

          <blockquote>
            <strong>★★★★★</strong>
            <p>Livraison rapide, excellente communication et résultat au-delà de nos attentes.</p>
            <cite>Marie-Eve L.<span>Agence immobilière</span></cite>
          </blockquote>

          <blockquote>
            <strong>★★★★★</strong>
            <p>F2D2 comprend vraiment nos besoins et le visuel est toujours sur la coche.</p>
            <cite>Alexandre T.<span>Événements</span></cite>
          </blockquote>
        </div>
      </section>

      <section class="f2d2-corporate-cta">
        <div>
          <p>Prêt à faire rayonner votre marque ?</p>
          <h2>Demander une<br>soumission</h2>
          <a href="{{ quote_target }}" data-f2d2-clothing-quote-open>Commencer maintenant</a>
        </div>

        <ul>
          <li>Réponse rapide</li>
          <li>Soumission gratuite</li>
          <li>Aucun engagement</li>
        </ul>
      </section>
    </div>
  </section>

  <style>
    body:has(.f2d2-corporate-page) .breadcrumbs,
    body:has(.f2d2-corporate-page) .collection-hero,
    body:has(.f2d2-corporate-page) .collection-section {
      display: none !important;
    }

    .section-{{ section.id }}.f2d2-corporate-page {
      --corp-bg: #02070d;
      --corp-panel: #07111b;
      --corp-panel-2: #091624;
      --corp-ink: #ffffff;
      --corp-muted: rgba(255, 255, 255, 0.68);
      --corp-line: rgba(255, 255, 255, 0.08);
      --corp-line-soft: rgba(255, 255, 255, 0.05);
      --corp-blue: #0a84ff;
      --corp-blue-strong: #0054c8;
      --corp-soft: rgba(10, 132, 255, 0.14);
      background:
        radial-gradient(circle at 50% 12%, rgba(10, 132, 255, 0.09), transparent 34rem),
        var(--corp-bg);
      color: var(--corp-ink);
    }

    .section-{{ section.id }} .f2d2-corporate__wrap {
      width: min(100% - 3.2rem, 150rem);
      margin-inline: auto;
    }

    .section-{{ section.id }} .f2d2-corporate-hero {
      position: relative;
      min-height: clamp(58rem, 72vh, 82rem);
      overflow: hidden;
      background: #02070d;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 2.4rem 6rem rgba(0, 0, 0, 0.34);
    }

    .section-{{ section.id }} .f2d2-corporate-hero__media,
    .section-{{ section.id }} .f2d2-corporate-hero__media::after {
      position: absolute;
      inset: 0;
    }

    .section-{{ section.id }} .f2d2-corporate-hero__media::after {
      content: "";
      background:
        linear-gradient(90deg, rgba(2, 7, 13, 0.88) 0%, rgba(2, 7, 13, 0.72) 34%, rgba(2, 7, 13, 0.30) 66%, rgba(2, 7, 13, 0.04) 100%),
        linear-gradient(180deg, rgba(2, 7, 13, 0), rgba(2, 7, 13, 0.62)),
        radial-gradient(circle at 28% 48%, rgba(10, 132, 255, 0.14), transparent 32rem);
    }

    .section-{{ section.id }} .f2d2-corporate-hero__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center right;
      display: block;
    }

    .section-{{ section.id }} .f2d2-corporate-hero__inner {
      position: relative;
      z-index: 1;
      min-height: inherit;
      display: flex;
      align-items: center;
      padding-block: clamp(7rem, 8vw, 11rem);
    }

    .section-{{ section.id }} .f2d2-corporate-hero__copy {
      max-width: 72rem;
    }

    .section-{{ section.id }} .f2d2-corporate__eyebrow {
      margin: 0 0 1.4rem;
      color: #5ea7ff;
      font-size: 1.25rem;
      font-weight: 900;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .section-{{ section.id }} .f2d2-corporate-hero h1 {
      max-width: 74rem;
      margin: 0;
      color: #ffffff;
      font-size: clamp(4.6rem, 5.4vw, 8.2rem);
      line-height: 0.92;
      letter-spacing: -0.035em;
      text-transform: uppercase;
    }

    .section-{{ section.id }} .f2d2-corporate-hero p:not(.f2d2-corporate__eyebrow) {
      max-width: 56rem;
      margin: 2.2rem 0 0;
      color: rgba(255, 255, 255, 0.86);
      font-size: clamp(1.65rem, 1.35vw, 2rem);
      line-height: 1.5;
    }

    .section-{{ section.id }} .f2d2-corporate__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1.4rem;
      margin-top: 3.2rem;
    }

    .section-{{ section.id }} .f2d2-corporate-btn,
    .section-{{ section.id }} .f2d2-corporate-volume a,
    .section-{{ section.id }} .f2d2-corporate-cta a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 5rem;
      padding: 0 2.4rem;
      color: #ffffff;
      font-size: 1.18rem;
      font-weight: 900;
      text-decoration: none;
      text-transform: uppercase;
      transition: transform 180ms ease, border-color 180ms ease, background 180ms ease, box-shadow 180ms ease;
    }

    .section-{{ section.id }} .f2d2-corporate-btn:hover,
    .section-{{ section.id }} .f2d2-corporate-volume a:hover,
    .section-{{ section.id }} .f2d2-corporate-cta a:hover {
      transform: translateY(-2px);
    }

    .section-{{ section.id }} .f2d2-corporate-btn--primary,
    .section-{{ section.id }} .f2d2-corporate-volume a,
    .section-{{ section.id }} .f2d2-corporate-cta a {
      border: 1px solid var(--corp-blue);
      background: linear-gradient(180deg, var(--corp-blue), var(--corp-blue-strong));
      box-shadow: 0 1.4rem 3.2rem rgba(0, 84, 200, 0.30);
    }

    .section-{{ section.id }} .f2d2-corporate-btn--ghost {
      border: 1px solid rgba(255, 255, 255, 0.22);
      background: rgba(255, 255, 255, 0.04);
    }

    .section-{{ section.id }} .f2d2-corporate-intro {
      position: relative;
      isolation: isolate;
      display: grid;
      grid-template-columns: minmax(0, 1.42fr) minmax(38rem, 0.95fr) minmax(42rem, 1fr);
      gap: 0;
      align-items: stretch;
      min-height: 42rem;
      max-width: 148rem;
      margin: clamp(5rem, 5vw, 8rem) auto 0;
      padding: 0;
      overflow: hidden;
      background: transparent;
      border: 0;
    }

    .section-{{ section.id }} .f2d2-corporate-intro > * {
      position: relative;
      z-index: 1;
    }

    .section-{{ section.id }} .f2d2-corporate-benefits-block {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(3.2rem, 3vw, 5rem);
      background: rgba(2, 7, 13, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .section-{{ section.id }} .f2d2-corporate-intro .f2d2-corporate-process,
    .section-{{ section.id }} .f2d2-corporate-intro .f2d2-corporate-volume {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 100%;
      padding: clamp(3.2rem, 3vw, 5rem);
      background: rgba(2, 7, 13, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .section-{{ section.id }} .f2d2-corporate-section {
      margin-top: clamp(6.5rem, 6vw, 9.5rem);
      padding-top: clamp(5rem, 5vw, 7.5rem);
      border-top: 1px solid var(--corp-line-soft);
    }

    .section-{{ section.id }} .f2d2-corporate-section__head {
      margin-bottom: 2.4rem;
    }

    .section-{{ section.id }} .f2d2-corporate-section__head--split {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.6rem;
    }

    .section-{{ section.id }} h2 {
      margin: 0;
      color: var(--corp-ink);
      font-size: clamp(2.4rem, 2vw, 3.4rem);
      line-height: 1.08;
      letter-spacing: -0.02em;
      text-transform: uppercase;
    }

    .section-{{ section.id }} h3 {
      margin: 0;
      color: var(--corp-ink);
      font-size: 1.45rem;
      line-height: 1.18;
      text-transform: uppercase;
    }

    .section-{{ section.id }} p {
      margin: 0;
    }

    .section-{{ section.id }} .f2d2-corporate-section__head a,
    .section-{{ section.id }} .f2d2-corporate-categories span {
      color: var(--corp-blue);
      font-size: 1.32rem;
      font-weight: 900;
      text-decoration: none;
    }

    .section-{{ section.id }} .f2d2-corporate-benefits,
    .section-{{ section.id }} .f2d2-corporate-categories,
    .section-{{ section.id }} .f2d2-corporate-gallery,
    .section-{{ section.id }} .f2d2-corporate-reviews__grid {
      display: grid;
      gap: 1.6rem;
    }

    .section-{{ section.id }} .f2d2-corporate-benefits {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1.6rem;
    }

    .section-{{ section.id }} .f2d2-corporate-benefits article,
    .section-{{ section.id }} .f2d2-corporate-categories article,
    .section-{{ section.id }} .f2d2-corporate-process,
    .section-{{ section.id }} .f2d2-corporate-reviews blockquote,
    .section-{{ section.id }} .f2d2-corporate-volume,
    .section-{{ section.id }} .f2d2-corporate-cta {
      background: var(--corp-panel);
      border: 1px solid var(--corp-line);
      transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
    }

    .section-{{ section.id }} .f2d2-corporate-benefits article:hover,
    .section-{{ section.id }} .f2d2-corporate-categories article:hover,
    .section-{{ section.id }} .f2d2-corporate-reviews blockquote:hover {
      border-color: rgba(10, 132, 255, 0.36);
      box-shadow: 0 0 30px rgba(10, 132, 255, 0.12);
    }

    .section-{{ section.id }} .f2d2-corporate-benefits article {
      min-height: 16.5rem;
      padding: 2rem;
      background: var(--corp-panel);
    }

    .section-{{ section.id }} .f2d2-corporate-benefits span {
      display: inline-flex;
      width: 4.8rem;
      height: 4.8rem;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.2rem;
      color: var(--corp-blue);
      background: var(--corp-soft);
    }

    .section-{{ section.id }} svg {
      width: 2.8rem;
      height: 2.8rem;
      fill: none;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 1.8;
    }

    .section-{{ section.id }} .f2d2-corporate-benefits p,
    .section-{{ section.id }} .f2d2-corporate-categories p,
    .section-{{ section.id }} .f2d2-corporate-process span,
    .section-{{ section.id }} .f2d2-corporate-volume p,
    .section-{{ section.id }} .f2d2-corporate-reviews p {
      color: var(--corp-muted);
      font-size: 1.35rem;
      line-height: 1.45;
    }

    .section-{{ section.id }} .f2d2-corporate-benefits p {
      margin-top: 0.8rem;
    }

    .section-{{ section.id }} .f2d2-corporate-process {
      text-align: center;
    }

    .section-{{ section.id }} .f2d2-corporate-process ol {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.4rem 1rem;
      margin: 2rem 0 0;
      padding: 0;
      list-style: none;
      counter-reset: process;
    }

    .section-{{ section.id }} .f2d2-corporate-process li {
      counter-increment: process;
      position: relative;
      display: grid;
      gap: 0.6rem;
      padding-top: 3.8rem;
    }

    .section-{{ section.id }} .f2d2-corporate-process li::before {
      content: counter(process);
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      display: grid;
      width: 2.7rem;
      height: 2.7rem;
      place-items: center;
      color: #ffffff;
      background: var(--corp-blue);
      border-radius: 50%;
      font-size: 1.2rem;
      font-weight: 900;
    }

    .section-{{ section.id }} .f2d2-corporate-process strong {
      font-size: 1.18rem;
      text-transform: uppercase;
    }

    .section-{{ section.id }} .f2d2-corporate-volume {
      position: relative;
      overflow: hidden;
      background: #02070d;
    }

    .section-{{ section.id }} .f2d2-corporate-volume::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      background: rgba(0, 0, 0, 0.65);
      pointer-events: none;
    }

    .section-{{ section.id }} .f2d2-corporate-volume img {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 1;
    }

    .section-{{ section.id }} .f2d2-corporate-volume div {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100%;
      padding: clamp(3rem, 4vw, 5rem);
      text-align: center;
      background: transparent;
    }

    .section-{{ section.id }} .f2d2-corporate-volume p {
      max-width: 42rem;
      margin-top: 1.2rem;
      color: rgba(255, 255, 255, 0.82);
    }

    .section-{{ section.id }} .f2d2-corporate-volume a {
      margin-top: 1.8rem;
      min-width: min(100%, 25rem);
    }

    .section-{{ section.id }} .f2d2-corporate-categories {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .section-{{ section.id }} .f2d2-corporate-categories article {
      overflow: hidden;
    }

    .section-{{ section.id }} .f2d2-corporate-categories a {
      display: grid;
      grid-template-rows: 21rem 1fr;
      min-height: 42rem;
      color: inherit;
      text-decoration: none;
    }

    .section-{{ section.id }} .f2d2-corporate-categories img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
    }

    .section-{{ section.id }} .f2d2-corporate-categories div {
      display: flex;
      flex-direction: column;

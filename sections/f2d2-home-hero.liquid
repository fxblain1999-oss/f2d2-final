{% assign section_id = 'f2d2-hero-' | append: section.id %}
{% assign hero_image = section.settings.image | default: 'hero-bg.png' %}

<section id="{{ section_id }}" class="f2d2-home-hero">

  <div class="f2d2-home-hero__media">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 2200 | image_tag: class: 'f2d2-home-hero__image', loading: 'eager', alt: section.settings.title | escape }}
    {% else %}
      <img src="{{ hero_image | asset_url }}" class="f2d2-home-hero__image" alt="{{ section.settings.title | escape }}">
    {% endif %}
  </div>

  <div class="f2d2-home-hero__overlay"></div>

  <div class="page-width f2d2-home-hero__inner">
    <div class="f2d2-home-hero__content">
      {% if section.settings.eyebrow != blank %}
        <p class="f2d2-home-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h1 class="f2d2-home-hero__title">{{ section.settings.title | newline_to_br }}</h1>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="f2d2-home-hero__text rte">{{ section.settings.text }}</div>
      {% endif %}

      <div class="f2d2-home-hero__actions">
        <a href="https://f2d2.ca/collections/all" class="f2d2-btn f2d2-btn--primary">
          {{ section.settings.primary_label | default: 'Commander' }}
        </a>

        <a href="https://f2d2.ca/pages/contact" class="f2d2-btn f2d2-btn--secondary">
            {{ section.settings.secondary_label | default: 'Soumission' }}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    margin: 0 !important;
    padding: 0 !important;
    font-size: 0 !important;
    line-height: 0 !important;
  }

  #{{ section_id }} {
    position: relative;
    overflow: hidden;
    min-height: min({{ section.settings.mobile_height }}px, 72vh);
    font-size: var(--font-body-size);
    line-height: var(--font-body-line-height);
    color: #ffffff;
    background: #050505;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    border-bottom: 0;
  }

  #{{ section_id }} .f2d2-home-hero__topnav {
    display: none;
  }

  #{{ section_id }} .f2d2-home-hero__topnav-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 2vw, 2.8rem);
    flex-wrap: wrap;
    padding-top: 0.65rem;
    padding-bottom: 0.65rem;
  }

  #{{ section_id }} .f2d2-home-hero__toplink {
    color: #ffffff;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 0.96rem;
    font-weight: 800;
    line-height: 1;
  }

  #{{ section_id }} .f2d2-home-hero__toplink--active {
    color: #3b8cff;
  }

  #{{ section_id }} .f2d2-home-hero__media,
  #{{ section_id }} .f2d2-home-hero__overlay {
    position: absolute;
    inset: 0;
  }

  #{{ section_id }} .f2d2-home-hero__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center right;
    filter: saturate(0.95) contrast(1.05);
  }

  #{{ section_id }} .f2d2-home-hero__overlay {
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.88) 0%, rgba(0, 0, 0, 0.82) 32%, rgba(0, 0, 0, 0.44) 58%, rgba(0, 0, 0, 0.12) 100%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.02) 0%, rgba(255, 255, 255, 0) 100%);
  }

  #{{ section_id }} .f2d2-home-hero__inner {
    position: relative;
    z-index: 3;
    min-height: min({{ section.settings.mobile_height }}px, 72vh);
    display: flex;
    align-items: center;
    padding-top: 4.5rem;
    padding-bottom: 1.25rem;
  }

  #{{ section_id }} .f2d2-home-hero__content {
    width: 100%;
    max-width: 52rem;
    padding: 1rem 0;
  }

  #{{ section_id }} .f2d2-home-hero__eyebrow {
    margin: 0 0 1rem;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.76);
  }

  #{{ section_id }} .f2d2-home-hero__title {
    margin: 0;
    max-width: 11ch;
    font-size: clamp(2.4rem, 5vw, 4.8rem);
    line-height: 0.95;
    font-weight: 800;
    letter-spacing: -0.04em;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.35);
  }

  #{{ section_id }} .f2d2-home-hero__text {
    margin-top: 1.3rem;
    max-width: 37rem;
    font-size: clamp(1rem, 1.4vw, 1.32rem);
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.86);
  }

  #{{ section_id }} .f2d2-home-hero__text p {
    margin: 0;
  }

  #{{ section_id }} .f2d2-home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.9rem;
  }

  #{{ section_id }} .f2d2-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 13.5rem;
    min-height: 3.1rem;
    padding: 0.8rem 1.7rem;
    border: 1px solid rgba(255, 255, 255, 0.42);
    text-decoration: none;
    text-transform: uppercase;
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0.02em;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  #{{ section_id }} .f2d2-btn:hover {
    transform: translateY(-1px);
  }

  #{{ section_id }} .f2d2-btn--primary {
    color: #ffffff;
    border-color: #5ea7ff;
    background: linear-gradient(180deg, #1b7dff 0%, #0048b8 100%);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.22), 0 0 16px rgba(31, 116, 255, 0.22);
  }

  #{{ section_id }} .f2d2-btn--secondary {
    color: #ffffff;
    background: rgba(0, 0, 0, 0.24);
  }

  @media screen and (min-width: 990px) {
    #{{ section_id }} {
      min-height: min({{ section.settings.desktop_height }}px, 62vh);
    }

    #{{ section_id }} .f2d2-home-hero__inner {
      min-height: min({{ section.settings.desktop_height }}px, 62vh);
      padding-top: 5rem;
      padding-bottom: 1.5rem;
    }
  }

@media screen and (max-width: 749px) {

  #{{ section_id }} {
    min-height: 25svh;
    min-height: 25vh;
  }

  #{{ section_id }} .f2d2-home-hero__image {
    object-fit: cover;
    object-position: 82%;
  }

  #{{ section_id }} .f2d2-home-hero__inner {
    min-height: 65svh;
    min-height: 65vh;
    display: flex;
    align-items: center;
    justify-content: center;

    /* 👉 plus de respiration */
    padding: 5rem 1.5rem 3rem;
  }

  #{{ section_id }} .f2d2-home-hero__content {
    width: 100%;
    
    /* 👉 plus large */
    max-width: 28rem;

    margin: 0 auto;
    text-align: center;

    transform: translateY(0);
  }

    #{{ section_id }} .f2d2-home-hero__title {
    font-size: clamp(2.8rem, 10vw, 4rem);
    font-weight: 800;
    line-height: 1.05;

    color: #fff;

    -webkit-text-stroke: 0.4px rgba(255,255,255,0.15);

    text-shadow:
        1px 1px 0 rgba(0,0,0,0.7),
        2px 2px 4px rgba(0,0,0,0.9);

    }

    #{{ section_id }} .f2d2-home-hero__text {
    margin-top: 0.8rem;
    font-size: 1.05rem;
    line-height: 1.4;
    font-weight: 700;
    color: #fff;

    text-shadow:
        1px 1px 0 rgba(0,0,0,0.4),
        2px 2px 8px rgba(0,0,0,0.5);
    }

  #{{ section_id }} .f2d2-home-hero__actions {
    margin-top: 1.4rem;

    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

    #{{ section_id }} .f2d2-btn {
    width: 100%;

    /* 👉 plus gros visuellement */
    min-width: 100%;
    max-width: 20rem;

    min-height: 3.4rem;
    padding: 0.9rem 1.4rem;

    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;

    border-radius: 999px;

    /* 💎 effet premium */
    box-shadow:
        0 8px 20px rgba(0,0,0,0.35),
        inset 0 1px 0 rgba(255,255,255,0.2);

    transition: all 0.25s ease;
    }

    /* bouton principal */
    #{{ section_id }} .f2d2-btn--primary {
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    color: #fff;
    }

    /* bouton secondaire */
    #{{ section_id }} .f2d2-btn--secondary {
    background: rgba(255,255,255,0.08);
    color: #fff;
    backdrop-filter: blur(6px);
    }
}

</style>

{% schema %}
{
  "name": "F2D2 Home Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de fond"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Impression personnalisée DTF & UV DTF"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>T-shirts, vêtements et objets personnalisés</p><p><em>Production rapide. Qualité pro. Prix volume.</em></p>"
    },
    {
    "type": "text",
    "id": "primary_label",
    "label": "Texte bouton principal",
    "default": "Commander"
    },
    {
    "type": "url",
    "id": "primary_link",
    "label": "Lien bouton principal"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Bouton secondaire",
      "default": "Soumission"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Lien bouton secondaire"
    },
    {
      "type": "header",
      "content": "Navigation du haut"
    },
    {
      "type": "text",
      "id": "nav_label_1",
      "label": "Lien 1",
      "default": "DTF"
    },
    {
      "type": "url",
      "id": "nav_link_1",
      "label": "URL 1"
    },
    {
      "type": "text",
      "id": "nav_label_2",
      "label": "Lien 2",
      "default": "UV DTF"
    },
    {
      "type": "url",
      "id": "nav_link_2",
      "label": "URL 2"
    },
    {
      "type": "text",
      "id": "nav_label_3",
      "label": "Lien 3",
      "default": "Corporatif"
    },
    {
      "type": "url",
      "id": "nav_link_3",
      "label": "URL 3"
    },
    {
      "type": "text",
      "id": "nav_label_4",
      "label": "Lien 4",
      "default": "Produits"
    },
    {
      "type": "url",
      "id": "nav_link_4",
      "label": "URL 4"
    },
    {
      "type": "text",
      "id": "nav_label_5",
      "label": "Lien 5",
      "default": "Gravure"
    },
    {
      "type": "url",
      "id": "nav_link_5",
      "label": "URL 5"
    },
    {
      "type": "text",
      "id": "nav_label_6",
      "label": "Lien 6",
      "default": "Soumission"
    },
    {
      "type": "url",
      "id": "nav_link_6",
      "label": "URL 6"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Hauteur mobile",
      "min": 380,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Hauteur desktop",
      "min": 500,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 640
    }
  ],
  "presets": [
    {
      "name": "F2D2 Home Hero"
    }
  ]
}
{% endschema %}

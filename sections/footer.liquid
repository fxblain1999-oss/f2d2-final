{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{%- liquid
  assign socials = 'facebook,instagram,youtube,tiktok,twitter,pinterest,snapchat,tumblr,vimeo'
  assign socials_arr = socials | split: ','
  assign has_social_icons = false
  assign footer_contact_block = blank

  for social in socials_arr
    assign setting_key = 'social_' | append: social | append: '_link'
    if settings[setting_key] != blank
      assign has_social_icons = true
      break
    endif
  endfor

  for block in section.blocks
    if block.type == 'contact_information' and footer_contact_block == blank
      assign footer_contact_block = block
    endif
  endfor
-%}
{% style %}
  #shopify-section-{{ section.id }} {
    margin: 0 !important;
    padding: 0 !important;
    font-size: 0 !important;
    line-height: 0 !important;
    display: block !important;
  }

  .footer--compact {
    --footer-scale: 1.50; /* ajuste ici: 1.2 / 1.3 / 1.35 */

    background: linear-gradient(180deg, #101010 0%, #050505 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    padding: calc(2.1rem * var(--footer-scale)) 0 calc(1.9rem * var(--footer-scale));
  }

  .footer--compact motion-element {
    display: block;
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
  }

  .footer--compact-summary {
    position: relative;
    width: 100%;
    padding: calc(1rem * var(--footer-scale)) 0;
    text-align: center;
  }

  .footer--compact-summary::before,
  .footer--compact-summary::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
  }

  .footer--compact-summary::before {
    top: 0;
  }

  .footer--compact-summary::after {
    bottom: 0;
  }

  .footer--compact-brand {
    margin: 0;
    font-size: clamp(1.35rem, calc(1.8vw * var(--footer-scale)), 2rem);
    font-weight: 700;
    line-height: 1.1;
    color: #f5f5f5;
  }

  .footer--compact-brand strong {
    color: #4d8dff;
    font-weight: 800;
  }

  .footer--compact-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: calc(1.35rem * var(--footer-scale));
    flex-wrap: wrap;
    margin-top: calc(0.7rem * var(--footer-scale));
    color: rgba(255, 255, 255, 0.84);
    font-size: calc(0.92rem * var(--footer-scale));
    line-height: 1.1;
  }

  .footer--compact-item,
  .footer--compact-item a {
    display: inline-flex;
    align-items: center;
    gap: calc(0.45rem * var(--footer-scale));
    color: inherit;
    text-decoration: none;
  }

  .footer--compact-item svg,
  .footer--compact-social .social__link svg {
    width: calc(1rem * var(--footer-scale));
    height: calc(1rem * var(--footer-scale));
  }

  .footer--compact-social .socials {
    gap: calc(0.8rem * var(--footer-scale));
  }

  .footer--compact-social .social__link {
    color: rgba(255, 255, 255, 0.84);
  }

  /* optionnel: footer plus large */
  .footer--compact .page-width {
    max-width: 1500px;
  }

  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} .footer--compact {
    background: linear-gradient(180deg, #101010 0%, #050505 100%) !important;
  }

  #shopify-section-{{ section.id }} .color-{{ section.settings.color_scheme }} {
    background: transparent !important;
  }  

  @media (max-width: 767.98px) {
    .footer--compact {
      padding: 1.6rem 0 1.4rem;
    }

    .footer--compact-meta {
      gap: 0.9rem;
      font-size: 0.86rem;
    }
  }
{% endstyle %}
<footer class="footer footer--compact color-{{ section.settings.color_scheme }}">
  {% render 'divider',
    show_divider: section.settings.show_section_divider,
    divider_width: section.settings.divider_width
  %}
  <div class="page-width">
    <motion-element class="block" data-motion="fade-up" data-motion-delay="50">
      <div class="footer--compact-summary">
        <p class="footer--compact-brand">Cr&eacute;ation <strong>F2D2</strong> inc</p>
        <div class="footer--compact-meta">
          {% if footer_contact_block != blank and footer_contact_block.settings.email != blank %}
            <span class="footer--compact-item">
              <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M2.5 4.375H17.5V15C17.5 15.1658 17.4342 15.3247 17.3169 15.4419C17.1997 15.5592 17.0408 15.625 16.875 15.625H3.125C2.95924 15.625 2.80027 15.5592 2.68306 15.4419C2.56585 15.3247 2.5 15.1658 2.5 15V4.375Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M17.5 4.375L10 11.25L2.5 4.375" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <a href="mailto:{{ footer_contact_block.settings.email }}">{{ footer_contact_block.settings.email }}</a>
            </span>
          {% endif %}

          {% if footer_contact_block != blank and footer_contact_block.settings.phone != blank %}
            <span class="footer--compact-item">
              <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M15 16.875L15 3.125C15 2.43464 14.4404 1.875 13.75 1.875L6.25 1.875C5.55964 1.875 5 2.43464 5 3.125L5 16.875C5 17.5654 5.55964 18.125 6.25 18.125H13.75C14.4404 18.125 15 17.5654 15 16.875Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 5.625C10.5178 5.625 10.9375 5.20527 10.9375 4.6875C10.9375 4.16973 10.5178 3.75 10 3.75C9.48223 3.75 9.0625 4.16973 9.0625 4.6875C9.0625 5.20527 9.48223 5.625 10 5.625Z" fill="currentColor"/>
              </svg>
              <a href="tel:{{ footer_contact_block.settings.phone }}">{{ footer_contact_block.settings.phone }}</a>
            </span>
          {% endif %}

          {% if has_social_icons %}
            <div class="footer--compact-social">
              {% render 'social-icons', class: 'footer__list-social', size: 'small' %}
            </div>
          {% endif %}
        </div>
      </div>
    </motion-element>
  </div>
</footer>
